{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-deny-destructive.sh",
            "timeout": 10,
            "statusMessage": "Checking command against the destructive-command guard"
          }
        ]
      }
    ]
  }
}
