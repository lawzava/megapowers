#!/usr/bin/env bash
set -euo pipefail

# Covered by scripts/tests/sdd-run.test.sh.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export MP_PROGRAM=sdd-run
# The library path is resolved from this script's runtime location.
# shellcheck disable=SC1091
source "$HERE/run-lib.sh"

mp_need_value() {
  if [ "$1" -lt 2 ]; then
    mp_die "missing value for $2" 2
    return
  fi
}

mp_positive_integer() {
  if ! [[ "$2" =~ ^[1-9][0-9]*$ ]]; then
    mp_die "$1 must be a positive integer" 2
    return
  fi
}

mp_harness() {
  case "$1" in
    codex|claude) ;;
    *) mp_die "harness must be codex or claude" 2 || return ;;
  esac
}

mp_object_id() {
  case "$(git rev-parse --show-object-format)" in
    sha1) [[ "$1" =~ ^[0-9a-f]{40}$ ]] ;;
    sha256) [[ "$1" =~ ^[0-9a-f]{64}$ ]] ;;
    *) return 1 ;;
  esac
}

mp_generation_ref() {
  mp_run_ref "$1" generation
}

mp_generation_oid() {
  local run=$1 previous=$2 operation=$3 data=$4
  jq -cn --arg run_id "$run" --arg previous "$previous" \
    --arg operation "$operation" --argjson data "$data" \
    '{version:1,run_id:$run_id,previous:$previous,operation:$operation,data:$data}' |
    git hash-object -w --stdin
}

mp_generation_moved() {
  local ref=$1 expected=$2 current
  current=$(mp_read_ref "$ref" || true)
  [ "$current" != "$expected" ]
}

mp_ref_oid_or_zero() {
  mp_read_ref "$1" || mp_zero_oid
}

mp_verifications_current() {
  local line command ref expected
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    command=${line%% *}
    line=${line#* }
    ref=${line%% *}
    expected=${line#* }
    [ "$command" = verify ] || return 1
    [ "$(mp_ref_oid_or_zero "$ref")" = "$expected" ] || return 1
  done <<<"$1"
}

mp_generation_retry() {
  local attempt=$1
  if [ "$attempt" -ge 200 ]; then
    mp_die "run generation is too contended" 4
    return
  fi
  sleep 0.02
}

mp_read_result_json() {
  git show "$1:result.json" 2>/dev/null | jq -ce .
}

mp_json_is_stale() {
  local document=$1 seconds=${2:-900}
  jq -e --arg now "$(mp_now)" --argjson seconds "$seconds" '
    def stale($now; $seconds):
      (($now | fromdateiso8601) - (.last_activity | fromdateiso8601)) > $seconds;
    (. + {last_activity: (.last_activity // .claimed_at)}) |
    stale($now; $seconds)' >/dev/null <<<"$document"
}

mp_redact_file() {
  local redactions=$1 source=$2 sanitized=$3
  awk '
    FILENAME == ARGV[1] { if (length($0) > 0) secret[++count] = $0; next }
    {
      line = $0
      out = ""
      while (length(line) > 0) {
        best = 0
        which = 0
        for (i = 1; i <= count; i++) {
          at = index(line, secret[i])
          if (at > 0 && (best == 0 || at < best ||
              (at == best && length(secret[i]) > length(secret[which])))) {
            best = at
            which = i
          }
        }
        if (best == 0) {
          out = out line
          break
        }
        out = out substr(line, 1, best - 1) "[REDACTED]"
        line = substr(line, best + length(secret[which]))
      }
      print out
    }
  ' "$redactions" "$source" > "$sanitized"
}

mp_contains_credential() {
  LC_ALL=C grep -Eiq \
    '(authorization:[[:space:]]*(bearer|basic)[[:space:]]+[^[]|api[_-]?key[[:space:]]*[:=][[:space:]]*[^[]|access[_-]?token[[:space:]]*[:=][[:space:]]*[^[]|secret[[:space:]]*[:=][[:space:]]*[^[]|password[[:space:]]*[:=][[:space:]]*[^[])' \
    "$1"
}

mp_report_native_ref_locks() {
  local ref lock found=0 packed
  for ref in "$@"; do
    lock=$(git rev-parse --git-path "$ref.lock" 2>/dev/null || true)
    if [ -n "$lock" ] && [ -e "$lock" ]; then
      printf '%s: native Git ref lock exists: %s\n' "$MP_PROGRAM" "$lock" >&2
      found=1
    fi
  done
  packed=$(git rev-parse --git-path packed-refs.lock 2>/dev/null || true)
  if [ -n "$packed" ] && [ -e "$packed" ]; then
    printf '%s: native Git ref lock exists: %s\n' "$MP_PROGRAM" "$packed" >&2
    found=1
  fi
  if [ "$found" -eq 1 ]; then
    printf '%s: confirm no Git process is using the lock, then remove it manually; ambiguous locks are never deleted automatically\n' \
      "$MP_PROGRAM" >&2
    return 0
  fi
  return 1
}

MP_OPEN_STATE_VERIFICATIONS=''
MP_OPEN_CLOSING_REF=''
MP_OPEN_CLOSED_REF=''

mp_require_run_open() {
  local run=$1 zero
  MP_OPEN_CLOSING_REF=$(mp_run_ref "$run" closing) || return
  MP_OPEN_CLOSED_REF=$(mp_run_ref "$run" closed) || return
  zero=$(mp_zero_oid) || return
  if [ "$(mp_ref_oid_or_zero "$MP_OPEN_CLOSING_REF")" != "$zero" ] ||
     [ "$(mp_ref_oid_or_zero "$MP_OPEN_CLOSED_REF")" != "$zero" ]; then
    mp_die "run is closing or closed" 4
    return
  fi
  MP_OPEN_STATE_VERIFICATIONS="verify $MP_OPEN_CLOSING_REF $zero
verify $MP_OPEN_CLOSED_REF $zero
"
}

mp_run_is_open() {
  local run=$1 closing_ref closed_ref zero
  closing_ref=$(mp_run_ref "$run" closing) || return
  closed_ref=$(mp_run_ref "$run" closed) || return
  zero=$(mp_zero_oid) || return
  [ "$(mp_ref_oid_or_zero "$closing_ref")" = "$zero" ] &&
    [ "$(mp_ref_oid_or_zero "$closed_ref")" = "$zero" ]
}

mp_run_branch_worktrees_clear() {
  local run=$1 worktrees line key value
  worktrees=$(git worktree list --porcelain) || return 3
  while IFS= read -r line; do
    key=${line%% *}
    value=${line#* }
    if [ "$key" = branch ]; then
      case "$value" in "refs/heads/mp/$run/"*) return 1 ;; esac
    fi
  done <<<"$worktrees"
  return 0
}

mp_cleanup_worktrees_clear() {
  local run=$1 top tool_root worktrees line key value path
  top=$(git rev-parse --show-toplevel) || return 3
  tool_root="$top/.worktrees/$run"
  worktrees=$(git worktree list --porcelain) || return 3
  while IFS= read -r line; do
    key=${line%% *}
    value=${line#* }
    case "$key" in
      worktree)
        path=$value
        case "$path/" in "$tool_root/"*) return 1 ;; esac
        ;;
      branch)
        case "$value" in "refs/heads/mp/$run/"*) return 1 ;; esac
        ;;
    esac
  done <<<"$worktrees"
  return 0
}

MP_CLOSE_RESULT_VERIFICATIONS=''
MP_CLOSE_RESULT_REFS=()

mp_prepare_close_snapshot() {
  local run=$1 manifest=$2 target_head=$3 refs root result_ref result_oid result result_head node
  MP_CLOSE_RESULT_VERIFICATIONS=''
  MP_CLOSE_RESULT_REFS=()
  refs=$(LC_ALL=C git for-each-ref --format='%(refname) %(objectname)' \
    "$(mp_run_ref "$run" nodes)/") || return
  while IFS= read -r root; do
    result_ref=$(mp_run_ref "$run" "nodes/$root/result") || return
    result_oid=''
    while IFS=' ' read -r ref_oid_name ref_oid_value; do
      [ "$ref_oid_name" = "$result_ref" ] && result_oid=$ref_oid_value
    done <<<"$refs"
    [ -n "$result_oid" ] || { mp_die "root does not have a result: $root" 4; return; }
    result=$(mp_read_result_json "$result_oid") || { mp_die "root result is malformed: $root" 3; return; }
    jq -e '.status == "done" and (.head | type == "string")' >/dev/null <<<"$result" || {
      mp_die "root result is not terminal done: $root" 4
      return
    }
  done < <(jq -r '.roots[]' <<<"$manifest")
  while IFS=' ' read -r result_ref result_oid; do
    [ -n "$result_ref" ] || continue
    case "$result_ref" in */result) ;; *) continue ;; esac
    node=${result_ref#"$(mp_run_ref "$run" nodes)/"}
    node=${node%/result}
    result=$(mp_read_result_json "$result_oid") || { mp_die "node result is malformed: $node" 3; return; }
    jq -e '(.head | type == "string")' >/dev/null <<<"$result" || {
      mp_die "node result head is missing: $node" 3
      return
    }
    result_head=$(jq -r '.head' <<<"$result")
    [ "$(git cat-file -t "$result_head" 2>/dev/null || true)" = commit ] || {
      mp_die "node result head is not a commit: $node" 3
      return
    }
    git merge-base --is-ancestor "$result_head" "$target_head" 2>/dev/null || {
      mp_die "node result is not integrated into the target: $node" 4
      return
    }
    MP_CLOSE_RESULT_VERIFICATIONS="${MP_CLOSE_RESULT_VERIFICATIONS}verify $result_ref $result_oid
"
    MP_CLOSE_RESULT_REFS+=("$result_ref")
  done <<<"$refs"
}

mp_report_close_native_locks() {
  mp_report_native_ref_locks "$@" "${MP_CLOSE_RESULT_REFS[@]}"
}

mp_nodes_related() {
  case "$1/" in
    "$2/"*) return 0 ;;
  esac
  case "$2/" in
    "$1/"*) return 0 ;;
  esac
  return 1
}

mp_ownership_overlap() {
  local left=$1 right=$2 left_interface=0 right_interface=0
  left=$(mp_canonical_ownership_path "$left") || return
  right=$(mp_canonical_ownership_path "$right") || return
  case "$left" in interface:*) left_interface=1 ;; esac
  case "$right" in interface:*) right_interface=1 ;; esac
  if [ "$left_interface" -eq 1 ] && [ "$right_interface" -eq 1 ]; then
    [ "$left" = "$right" ]
    return
  fi
  if [ "$left_interface" -eq 1 ] || [ "$right_interface" -eq 1 ]; then
    return 1
  fi
  [ "$left" = . ] || [ "$right" = . ] && return 0
  [ "$left" = "$right" ] && return 0
  case "$left/" in
    "$right/"*) return 0 ;;
  esac
  case "$right/" in
    "$left/"*) return 0 ;;
  esac
  return 1
}

mp_canonical_ownership_path() {
  local path=$1 segment result='' more
  case "$path" in
    interface:*) printf '%s\n' "$path"; return ;;
  esac
  while :; do
    case "$path" in
      */*) segment=${path%%/*}; path=${path#*/}; more=1 ;;
      *) segment=$path; path=''; more=0 ;;
    esac
    case "$segment" in
      ''|.) ;;
      *)
        if [ -n "$result" ]; then result="$result/$segment"
        else result=$segment
        fi
        ;;
    esac
    [ "$more" -eq 1 ] || break
  done
  [ -n "$result" ] || result=.
  printf '%s\n' "$result"
}

mp_canonical_brief_json() {
  jq -ce '
    def canonical_ownership:
      if startswith("interface:") then .
      else (split("/") | map(select(length > 0 and . != "."))) as $segments |
        if ($segments | length) == 0 then "." else ($segments | join("/")) end
      end;
    .ownership |= map(canonical_ownership)' <<<"$1"
}

mp_brief_contract() {
  local brief=$1
  jq -e \
    '(.version == 1) and
     (.run_id | type == "string") and
     (.node | type == "string") and
     ((.parent == null) or (.parent | type == "string")) and
     (.base | type == "string") and
     (.branch | type == "string") and
     (.task | type == "string" and length > 0) and
     (.acceptance | type == "array" and length > 0 and all(.[]; type == "string")) and
     (.blocked_by | type == "array" and all(.[]; type == "string")) and
     (.parallel_safety == "Safe" or .parallel_safety == "Sequential") and
     (.ownership | type == "array" and length > 0 and all(.[]; type == "string")) and
     (.may_decompose | type == "boolean") and
     ((.remaining_depth | type) == "number" and .remaining_depth >= 0 and
       (.remaining_depth | floor) == .remaining_depth) and
     ((.descendant_budget | type) == "number" and .descendant_budget >= 0 and
       (.descendant_budget | floor) == .descendant_budget) and
     ((.writer_budget | type) == "number" and .writer_budget >= 0 and
       (.writer_budget | floor) == .writer_budget) and
     ((.integration_budget | type) == "number" and .integration_budget >= 0 and
       (.integration_budget | floor) == .integration_budget)' \
    >/dev/null <<<"$brief"
}

mp_validate_ownership() {
  local brief=$1 ownership
  jq -e '
    all(.ownership[];
      length > 0 and
      (explode | all(.[]; . >= 32 and . != 127)) and
      (contains("..") | not) and
      (test("[*?\\[\\]]") | not) and
      (test("^[A-Za-z]:/") | not) and
      (test("\\\\") | not) and
      ((test("^interface:[A-Za-z0-9][A-Za-z0-9._-]*$")) or
       ((startswith("interface:") | not) and (startswith("/") | not))))' \
    >/dev/null <<<"$brief" || {
      mp_die "ownership must contain safe relative paths or interface names" 2
      return
    }
  while IFS= read -r ownership; do
    [ -n "$ownership" ] || {
      mp_die "ownership must not be empty" 2
      return
    }
  done < <(jq -r '.ownership[]' <<<"$brief")
}

mp_scope_ref() {
  local run=$1 brief=$2 parent target parent_brief
  if jq -e '.parent == null' >/dev/null <<<"$brief"; then
    target=$(mp_manifest_json "$run" | jq -r '.target_branch') || return
    printf 'refs/heads/%s\n' "$target"
    return
  fi
  parent=$(jq -r '.parent' <<<"$brief")
  parent_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$parent/brief")") || return
  target=$(jq -r '.branch' <<<"$parent_brief")
  printf 'refs/heads/%s\n' "$target"
}

MP_DEPENDENCY_VERIFICATIONS=''
MP_SCOPE_HEAD_REF=''
MP_SCOPE_HEAD_OID=''

mp_validate_dependencies() {
  local run=$1 brief=$2 dependency result result_head result_ref result_oid
  MP_DEPENDENCY_VERIFICATIONS=''
  MP_SCOPE_HEAD_REF=$(mp_scope_ref "$run" "$brief") || {
    mp_die "claim scope branch does not exist" 3
    return
  }
  MP_SCOPE_HEAD_OID=$(mp_read_ref "$MP_SCOPE_HEAD_REF") || {
    mp_die "claim scope branch does not exist" 3
    return
  }
  while IFS= read -r dependency; do
    result_ref=$(mp_run_ref "$run" "nodes/$dependency/result") || return
    result_oid=$(mp_read_ref "$result_ref") || {
      mp_die "blocked dependency is not done: $dependency" 4
      return
    }
    result=$(mp_read_result_json "$result_oid") || {
      mp_die "blocked dependency is not done: $dependency" 4
      return
    }
    jq -e '.status == "done" and (.head | type == "string")' >/dev/null \
      <<<"$result" || {
        mp_die "blocked dependency is not done: $dependency" 4
        return
    }
    result_head=$(jq -r '.head' <<<"$result")
    git merge-base --is-ancestor "$result_head" "$MP_SCOPE_HEAD_OID" 2>/dev/null || {
      mp_die "blocked dependency is not integrated: $dependency" 4
      return
    }
    MP_DEPENDENCY_VERIFICATIONS="${MP_DEPENDENCY_VERIFICATIONS}verify $result_ref $result_oid
"
  done < <(jq -r '.blocked_by[]' <<<"$brief")
}

mp_validate_claim_peers() {
  local run=$1 node=$2 session=$3 brief=$4 ref claim other_node other_brief
  local safety other_safety ours theirs
  safety=$(jq -r '.parallel_safety' <<<"$brief")
  while IFS= read -r ref; do
    case "$ref" in
      */claim) ;;
      *) continue ;;
    esac
    claim=$(mp_read_json_ref "$ref") || {
      mp_die "active claim is malformed: $ref" 3
      return
    }
    other_node=$(jq -r '.node' <<<"$claim")
    if [ "$other_node" != "$node" ] &&
       [ "$(jq -r '.session' <<<"$claim")" = "$session" ]; then
      mp_die "session already claims another node: $other_node" 4
      return
    fi
    mp_nodes_related "$node" "$other_node" && continue
    other_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$other_node/brief")") || {
      mp_die "active claim brief is missing: $other_node" 3
      return
    }
    other_safety=$(jq -r '.parallel_safety' <<<"$other_brief")
    if [ "$safety" = Sequential ] || [ "$other_safety" = Sequential ]; then
      mp_die "sequential node cannot run beside an active peer" 4
      return
    fi
    while IFS= read -r ours; do
      while IFS= read -r theirs; do
        if mp_ownership_overlap "$ours" "$theirs"; then
          mp_die "ownership overlaps active node: $other_node" 4
          return
        fi
      done < <(jq -r '.ownership[]' <<<"$other_brief")
    done < <(jq -r '.ownership[]' <<<"$brief")
  done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" nodes)/")
}

cmd_init() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run init RUN_ID [options]" 2
    return
  fi

  local run=$1
  shift
  mp_validate_run_id "$run" || return

  local plan='' target='' session='' harness='' max_depth='' agent_budget=''
  local writers=3 integrations=1
  local seen_plan=0 seen_target=0 seen_session=0 seen_harness=0
  local seen_max_depth=0 seen_agent_budget=0 seen_writers=0 seen_integrations=0
  local allow_task_commits=0 allow_protected_target=0
  local -a roots=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plan)
        mp_need_value "$#" "$1" || return
        [ "$seen_plan" -eq 0 ] || { mp_die "duplicate --plan" 2; return; }
        plan=$2
        seen_plan=1
        shift 2
        ;;
      --root)
        mp_need_value "$#" "$1" || return
        roots+=("$2")
        shift 2
        ;;
      --target)
        mp_need_value "$#" "$1" || return
        [ "$seen_target" -eq 0 ] || { mp_die "duplicate --target" 2; return; }
        target=$2
        seen_target=1
        shift 2
        ;;
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2
        seen_session=1
        shift 2
        ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2
        seen_harness=1
        shift 2
        ;;
      --max-depth)
        mp_need_value "$#" "$1" || return
        [ "$seen_max_depth" -eq 0 ] || { mp_die "duplicate --max-depth" 2; return; }
        max_depth=$2
        seen_max_depth=1
        shift 2
        ;;
      --agent-budget)
        mp_need_value "$#" "$1" || return
        [ "$seen_agent_budget" -eq 0 ] || { mp_die "duplicate --agent-budget" 2; return; }
        agent_budget=$2
        seen_agent_budget=1
        shift 2
        ;;
      --writers)
        mp_need_value "$#" "$1" || return
        [ "$seen_writers" -eq 0 ] || { mp_die "duplicate --writers" 2; return; }
        writers=$2
        seen_writers=1
        shift 2
        ;;
      --integrations)
        mp_need_value "$#" "$1" || return
        [ "$seen_integrations" -eq 0 ] || { mp_die "duplicate --integrations" 2; return; }
        integrations=$2
        seen_integrations=1
        shift 2
        ;;
      --allow-task-commits)
        [ "$allow_task_commits" -eq 0 ] || { mp_die "duplicate --allow-task-commits" 2; return; }
        allow_task_commits=1
        shift
        ;;
      --allow-protected-target)
        [ "$allow_protected_target" -eq 0 ] || { mp_die "duplicate --allow-protected-target" 2; return; }
        allow_protected_target=1
        shift
        ;;
      *)
        mp_die "unknown init option: $1" 2
        return
        ;;
    esac
  done

  [ "$seen_plan" -eq 1 ] || { mp_die "missing --plan" 2; return; }
  [ "${#roots[@]}" -gt 0 ] || { mp_die "at least one --root is required" 2; return; }
  [ "$seen_target" -eq 1 ] || { mp_die "missing --target" 2; return; }
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  [ "$seen_max_depth" -eq 1 ] || { mp_die "missing --max-depth" 2; return; }
  [ "$seen_agent_budget" -eq 1 ] || { mp_die "missing --agent-budget" 2; return; }
  [ "$allow_task_commits" -eq 1 ] || { mp_die "--allow-task-commits is required" 2; return; }

  [ -f "$plan" ] || { mp_die "no such plan file: $plan" 2; return; }
  mp_positive_integer "max-depth" "$max_depth" || return
  mp_positive_integer "agent-budget" "$agent_budget" || return
  mp_positive_integer "writers" "$writers" || return
  mp_positive_integer "integrations" "$integrations" || return
  [ "$max_depth" -le 5 ] || { mp_die "max-depth must be no greater than 5" 2; return; }
  [ "$agent_budget" -ge "${#roots[@]}" ] || { mp_die "agent-budget must cover every root" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local root seen_root
  local -a seen_roots=()
  for root in "${roots[@]}"; do
    mp_validate_node_path "$root" || return
    for seen_root in "${seen_roots[@]}"; do
      if [ "$seen_root" = "$root" ]; then
        mp_die "duplicate root: $root" 2
        return
      fi
      if mp_nodes_related "$seen_root" "$root"; then
        mp_die "manifest roots must not be ancestors of one another: $seen_root and $root" 2
        return
      fi
    done
    seen_roots+=("$root")
  done

  git check-ref-format --branch "$target" >/dev/null 2>&1 || {
    mp_die "invalid target branch: $target" 2
    return
  }
  git show-ref --verify --quiet "refs/heads/$target" || {
    mp_die "target branch does not exist: $target" 2
    return
  }
  local current_branch
  current_branch=$(git symbolic-ref --quiet --short HEAD) || {
    mp_die "current checkout is detached" 2
    return
  }
  [ "$current_branch" = "$target" ] || {
    mp_die "current checkout is not on target branch: $target" 2
    return
  }
  [ -z "$(git status --porcelain)" ] || {
    mp_die "current checkout must be clean" 2
    return
  }
  case "$target" in
    main|master|release)
      [ "$allow_protected_target" -eq 1 ] || {
        mp_die "protected target requires --allow-protected-target: $target" 2
        return
      }
      ;;
  esac

  local roots_json created_at manifest_oid plan_oid owner_oid generation_oid
  local manifest_ref plan_ref owner_ref generation_ref
  roots_json=$(printf '%s\n' "${roots[@]}" | jq -Rsc 'split("\n") | map(select(length > 0))')
  created_at=$(mp_now)
  manifest_oid=$(
    jq -cn \
      --arg run_id "$run" --arg target_branch "$target" \
      --arg target_base "$(git rev-parse HEAD)" --arg created_at "$created_at" \
      --argjson roots "$roots_json" --argjson max_depth "$max_depth" \
      --argjson agent_budget "$agent_budget" --argjson writer_limit "$writers" \
      --argjson integration_limit "$integrations" \
      '{version:1,run_id:$run_id,target_branch:$target_branch,target_base:$target_base,
        harnesses:["codex","claude"],roots:$roots,max_depth:$max_depth,
        agent_budget:$agent_budget,writer_limit:$writer_limit,
        integration_limit:$integration_limit,task_commits:true,created_at:$created_at}' |
      git hash-object -w --stdin
  )
  plan_oid=$(git hash-object -w "$plan")
  owner_oid=$(
    jq -cn --arg session "$session" --arg harness "$harness" \
      --arg at "$created_at" '{session:$session,harness:$harness,claimed_at:$at,last_activity:$at}' |
      git hash-object -w --stdin
  )
  generation_oid=$(
    jq -cn --arg run_id "$run" --arg manifest "$manifest_oid" --arg plan "$plan_oid" \
      --arg owner "$owner_oid" \
      '{version:1,run_id:$run_id,previous:null,operation:"init",
        data:{manifest:$manifest,plan:$plan,owner:$owner}}' |
      git hash-object -w --stdin
  )
  manifest_ref=$(mp_run_ref "$run" manifest) || return
  plan_ref=$(mp_run_ref "$run" plan) || return
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  if ! git update-ref --stdin <<EOF
start
create $manifest_ref $manifest_oid
create $plan_ref $plan_oid
create $owner_ref $owner_oid
create $generation_ref $generation_oid
prepare
commit
EOF
  then
    mp_die "run already exists or creation race was lost" 4
  fi
}

cmd_join() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run join RUN_ID --plan FILE --target BRANCH --harness codex|claude" 2
    return
  fi

  local run=$1
  shift
  mp_validate_run_id "$run" || return

  local plan='' target='' harness=''
  local seen_plan=0 seen_target=0 seen_harness=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plan)
        mp_need_value "$#" "$1" || return
        [ "$seen_plan" -eq 0 ] || { mp_die "duplicate --plan" 2; return; }
        plan=$2
        seen_plan=1
        shift 2
        ;;
      --target)
        mp_need_value "$#" "$1" || return
        [ "$seen_target" -eq 0 ] || { mp_die "duplicate --target" 2; return; }
        target=$2
        seen_target=1
        shift 2
        ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2
        seen_harness=1
        shift 2
        ;;
      *)
        mp_die "unknown join option: $1" 2
        return
        ;;
    esac
  done

  [ "$seen_plan" -eq 1 ] || { mp_die "missing --plan" 2; return; }
  [ "$seen_target" -eq 1 ] || { mp_die "missing --target" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  [ -f "$plan" ] || { mp_die "no such plan file: $plan" 2; return; }
  git check-ref-format --branch "$target" >/dev/null 2>&1 || {
    mp_die "invalid target branch: $target" 2
    return
  }
  mp_harness "$harness" || return

  local plan_ref expected_plan supplied_plan manifest
  plan_ref=$(mp_run_ref "$run" plan) || return
  expected_plan=$(mp_read_ref "$plan_ref") || {
    mp_die "run does not exist: $run" 3
    return
  }
  supplied_plan=$(git hash-object "$plan")
  [ "$supplied_plan" = "$expected_plan" ] || {
    mp_die "plan does not match immutable run state" 3
    return
  }
  manifest=$(mp_manifest_json "$run") || {
    mp_die "run manifest is missing or malformed" 3
    return
  }
  [ "$(jq -r '.target_branch' <<<"$manifest")" = "$target" ] || {
    mp_die "target branch does not match immutable run state" 3
    return
  }
  jq -e --arg harness "$harness" '.harnesses | index($harness) != null' \
    <<<"$manifest" >/dev/null || {
      mp_die "harness does not match immutable run state" 3
      return
    }
}

cmd_brief_put() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run brief-put RUN_ID NODE BRIEF.json --session ID" 2
    return
  fi

  local run=$1 node=$2 brief_file=$3 session='' seen_session=0
  shift 3
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  [ -f "$brief_file" ] || { mp_die "no such brief file: $brief_file" 2; return; }
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2
        seen_session=1
        shift 2
        ;;
      *) mp_die "unknown brief-put option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  mp_validate_session_id "$session" || return

  local snapshot_oid brief manifest document_run document_node expected_branch base
  local remaining descendant writers integrations may_decompose
  snapshot_oid=$(git hash-object -w -- "$brief_file") || {
    mp_die "could not snapshot brief" 2
    return
  }
  brief=$(git cat-file blob "$snapshot_oid") || {
    mp_die "could not read brief snapshot" 2
    return
  }
  manifest=$(mp_manifest_json "$run") || {
    mp_die "run does not exist: $run" 3
    return
  }
  mp_brief_contract "$brief" || {
    mp_die "brief does not match the version 1 contract" 2
    return
  }
  jq -e '.blocked_by | length == (unique | length)' >/dev/null <<<"$brief" || {
    mp_die "blocked_by must not contain duplicate nodes" 2
    return
  }
  document_run=$(jq -r '.run_id' <<<"$brief")
  document_node=$(jq -r '.node' <<<"$brief")
  [ "$document_run" = "$run" ] || { mp_die "brief run_id does not match command" 2; return; }
  [ "$document_node" = "$node" ] || { mp_die "brief node does not match command" 2; return; }
  expected_branch="mp/$run/nodes/$node/head"
  [ "$(jq -r '.branch' <<<"$brief")" = "$expected_branch" ] || {
    mp_die "brief branch must be $expected_branch" 2
    return
  }
  base=$(jq -r '.base' <<<"$brief")
  [ "$(git cat-file -t "$base" 2>/dev/null || true)" = commit ] || {
    mp_die "brief base must name a commit object" 2
    return
  }
  jq -e 'all(.blocked_by[]; (explode | all(.[]; . >= 32 and . != 127)))' \
    >/dev/null <<<"$brief" || { mp_die "blocked_by contains control characters" 2; return; }
  local dependency
  while IFS= read -r dependency; do
    mp_validate_node_path "$dependency" || return
  done < <(jq -r '.blocked_by[]' <<<"$brief")
  mp_validate_ownership "$brief" || return

  remaining=$(jq -r '.remaining_depth' <<<"$brief")
  descendant=$(jq -r '.descendant_budget' <<<"$brief")
  writers=$(jq -r '.writer_budget' <<<"$brief")
  integrations=$(jq -r '.integration_budget' <<<"$brief")
  may_decompose=$(jq -r '.may_decompose' <<<"$brief")
  if [ "$may_decompose" = true ]; then
    [ "$remaining" -gt 0 ] && [ "$descendant" -gt 0 ] || {
      mp_die "decomposable briefs require positive depth and descendant budget" 2
      return
    }
  else
    [ "$remaining" -eq 0 ] && [ "$descendant" -eq 0 ] || {
      mp_die "non-decomposable briefs require zero depth and descendant budget" 2
      return
    }
  fi

  local brief_json brief_oid brief_ref generation_ref generation_oid new_generation
  local generation_data attempt=0 parent current_head owner owner_ref total root root_brief parent_brief
  local parent_remaining parent_descendant parent_writers parent_integrations candidate_ref
  local authorization_ref authorization_oid head_ref
  brief_json=$(mp_canonical_brief_json "$brief") || {
    mp_die "could not canonicalize brief ownership" 2
    return
  }
  brief_oid=$(printf '%s\n' "$brief_json" | git hash-object -w --stdin) || {
    mp_die "could not hash brief" 2
    return
  }
  brief_ref=$(mp_run_ref "$run" "nodes/$node/brief") || return
  generation_ref=$(mp_generation_ref "$run") || return

  [ "$writers" -le "$(jq -r '.writer_limit' <<<"$manifest")" ] || {
    mp_die "writer budget exceeds the manifest limit" 2
    return
  }
  [ "$integrations" -le "$(jq -r '.integration_limit' <<<"$manifest")" ] || {
    mp_die "integration budget exceeds the manifest limit" 2
    return
  }

  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || {
      mp_die "run generation is missing" 3
      return
    }
    mp_require_run_open "$run" || return
    total=0
    if jq -e '.parent == null' >/dev/null <<<"$brief"; then
      jq -e --arg node "$node" '.roots | index($node) != null' >/dev/null \
        <<<"$manifest" || { mp_die "root node is not declared in the manifest" 2; return; }
      owner_ref=$(mp_run_ref "$run" owner) || return
      authorization_ref=$owner_ref
      authorization_oid=$(mp_read_ref "$authorization_ref") || { mp_die "run owner is missing" 3; return; }
      owner=$(mp_read_json_ref "$authorization_oid") || { mp_die "run owner is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$owner")" = "$session" ] || {
        mp_die "root brief requires the owner session" 4
        return
      }
      head_ref="refs/heads/$(jq -r '.target_branch' <<<"$manifest")"
      current_head=$(mp_read_ref "$head_ref") || { mp_die "target branch does not exist" 3; return; }
      [ "$base" = "$current_head" ] || { mp_die "root brief base is not the current target head" 4; return; }
      [ "$remaining" -le "$(jq -r '.max_depth' <<<"$manifest")" ] || {
        mp_die "root remaining depth exceeds the manifest limit" 2
        return
      }
      while IFS= read -r root; do
        [ "$root" = "$node" ] && continue
        if root_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$root/brief")"); then
          total=$((total + 1 + $(jq -r '.descendant_budget' <<<"$root_brief")))
        fi
      done < <(jq -r '.roots[]' <<<"$manifest")
      total=$((total + 1 + descendant))
      [ "$total" -le "$(jq -r '.agent_budget' <<<"$manifest")" ] || {
        mp_die "root briefs exceed the run agent budget" 4
        return
      }
    else
      parent=$(jq -r '.parent' <<<"$brief")
      case "$node" in */*) ;; *) mp_die "child node must be below its parent" 2; return ;; esac
      [ "${node%/*}" = "$parent" ] || {
        mp_die "child node must be exactly one segment below its parent" 2
        return
      }
      mp_validate_node_path "$parent" || return
      parent_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$parent/brief")") || {
        mp_die "parent brief does not exist" 3
        return
      }
      authorization_ref=$(mp_run_ref "$run" "nodes/$parent/claim") || return
      authorization_oid=$(mp_read_ref "$authorization_ref") || {
        mp_die "parent node is not actively claimed" 4
        return
      }
      owner=$(mp_read_json_ref "$authorization_oid") || { mp_die "parent claim is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$owner")" = "$session" ] || {
        mp_die "child brief requires the parent claimant session" 4
        return
      }
      head_ref="refs/heads/$(jq -r '.branch' <<<"$parent_brief")"
      current_head=$(mp_read_ref "$head_ref") || { mp_die "parent branch does not exist" 3; return; }
      [ "$base" = "$current_head" ] || { mp_die "child brief base is not the current parent head" 4; return; }
      parent_remaining=$(jq -r '.remaining_depth' <<<"$parent_brief")
      parent_descendant=$(jq -r '.descendant_budget' <<<"$parent_brief")
      parent_writers=$(jq -r '.writer_budget' <<<"$parent_brief")
      parent_integrations=$(jq -r '.integration_budget' <<<"$parent_brief")
      [ "$remaining" -lt "$parent_remaining" ] || {
        mp_die "child remaining depth must be smaller than its parent" 2
        return
      }
      while IFS= read -r candidate_ref; do
        case "$candidate_ref" in */brief) ;; *) continue ;; esac
        [ "$candidate_ref" = "$brief_ref" ] && continue
        root_brief=$(mp_read_json_ref "$candidate_ref") || continue
        [ "$(jq -r '.parent // ""' <<<"$root_brief")" = "$parent" ] || continue
        total=$((total + 1 + $(jq -r '.descendant_budget' <<<"$root_brief")))
      done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" "nodes/$parent")/")
      total=$((total + 1 + descendant))
      [ "$total" -le "$parent_descendant" ] || {
        mp_die "sibling briefs exceed the parent descendant budget" 4
        return
      }
      [ "$writers" -le "$parent_writers" ] || { mp_die "child writer budget exceeds its parent" 2; return; }
      [ "$integrations" -le "$parent_integrations" ] || { mp_die "child integration budget exceeds its parent" 2; return; }
    fi

    generation_data=$(jq -cn --arg node "$node" --arg snapshot "$snapshot_oid" \
      --arg brief "$brief_oid" --arg authorization "$authorization_oid" --arg head "$current_head" \
      '{node:$node,snapshot:$snapshot,brief:$brief,authorization:$authorization,head:$head}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" brief-put "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $authorization_ref $authorization_oid
verify $head_ref $current_head
create $brief_ref $brief_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before brief creation" 4; return; }
    if ! mp_generation_moved "$generation_ref" "$generation_oid"; then
      [ "$(mp_read_ref "$authorization_ref" || true)" = "$authorization_oid" ] || {
        mp_die "brief authorization changed" 4
        return
      }
      [ "$(mp_read_ref "$head_ref" || true)" = "$current_head" ] || {
        mp_die "brief scope branch changed" 4
        return
      }
      mp_read_ref "$brief_ref" >/dev/null && {
        mp_die "node brief already exists" 4
        return
      }
    fi
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_claim() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run claim RUN_ID NODE --session ID --harness codex|claude" 2
    return
  fi
  local run=$1 node=$2 session='' harness='' seen_session=0 seen_harness=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2; seen_harness=1; shift 2 ;;
      *) mp_die "unknown claim option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local brief_ref brief_oid brief result_ref result_oid result claim_ref generation_ref
  local generation_oid new_generation generation_data claim_oid at attempt=0
  brief_ref=$(mp_run_ref "$run" "nodes/$node/brief") || return
  result_ref=$(mp_run_ref "$run" "nodes/$node/result") || return
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    brief_oid=$(mp_read_ref "$brief_ref") || { mp_die "node brief does not exist" 3; return; }
    brief=$(mp_read_json_ref "$brief_oid") || { mp_die "node brief is malformed" 3; return; }
    result_oid=$(mp_ref_oid_or_zero "$result_ref")
    if [ "$result_oid" != "$(mp_zero_oid)" ]; then
      result=$(mp_read_result_json "$result_oid") || { mp_die "node result is malformed" 3; return; }
      if jq -e '.status == "done"' >/dev/null <<<"$result"; then
        mp_die "node already has a terminal done result" 4
        return
      fi
    fi
    mp_validate_dependencies "$run" "$brief" || return
    mp_validate_claim_peers "$run" "$node" "$session" "$brief" || return
    at=$(mp_now)
    generation_data=$(jq -cn --arg node "$node" --arg session "$session" \
      --arg harness "$harness" --arg brief "$brief_oid" --arg result "$result_oid" \
      --arg scope_head "$MP_SCOPE_HEAD_OID" \
      '{node:$node,session:$session,harness:$harness,brief:$brief,
        result:$result,scope_head:$scope_head}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" claim "$generation_data") || return
    claim_oid=$(
      printf '%s\n' "$brief" |
        jq -c --arg session "$session" --arg harness "$harness" --arg at "$at" \
          --arg generation "$new_generation" \
          '{session:$session,harness:$harness,node:.node,branch:.branch,base:.base,
            claimed_at:$at,last_activity:$at,generation:$generation}' |
        git hash-object -w --stdin
    )
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $brief_ref $brief_oid
verify $result_ref $result_oid
verify $MP_SCOPE_HEAD_REF $MP_SCOPE_HEAD_OID
${MP_DEPENDENCY_VERIFICATIONS}create $claim_ref $claim_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s %s\n' "$claim_oid" "$(jq -r '.branch' <<<"$brief")"
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before claim" 4; return; }
    [ "$(mp_ref_oid_or_zero "$brief_ref")" = "$brief_oid" ] || {
      mp_die "node brief changed before claim" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$result_ref")" = "$result_oid" ] || {
      mp_die "node result changed before claim" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$MP_SCOPE_HEAD_REF")" = "$MP_SCOPE_HEAD_OID" ] || {
      mp_die "claim scope branch changed" 4
      return
    }
    mp_verifications_current "$MP_DEPENDENCY_VERIFICATIONS" || {
      mp_die "claim dependency changed" 4
      return
    }
    mp_read_ref "$claim_ref" >/dev/null && { mp_die "node already claimed" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_heartbeat() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run heartbeat RUN_ID NODE --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 node=$2 session='' expected='' seen_session=0 seen_expected=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown heartbeat option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }

  local claim at new_oid claim_ref generation_ref generation_oid new_generation
  local generation_data attempt=0
  claim=$(mp_read_json_ref "$expected") || { mp_die "expected claim object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$claim")" = "$session" ] || {
    mp_die "claim belongs to another session" 4
    return
  }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    at=$(mp_now)
    generation_data=$(jq -cn --arg node "$node" --arg session "$session" \
      --arg expected "$expected" --arg at "$at" \
      '{node:$node,session:$session,expected:$expected,last_activity:$at}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" heartbeat "$generation_data") || return
    new_oid=$(printf '%s\n' "$claim" |
      jq -c --arg at "$at" --arg generation "$new_generation" \
        '.last_activity=$at | .generation=$generation' |
      git hash-object -w --stdin)
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}update $claim_ref $new_oid $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s\n' "$new_oid"
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before heartbeat" 4; return; }
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$expected" ] || {
      mp_die "claim changed before heartbeat" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_release_claim() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run release-claim RUN_ID NODE --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 node=$2 session='' expected='' seen_session=0 seen_expected=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown release-claim option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local claim claim_ref generation_ref generation_oid new_generation generation_data attempt=0
  claim=$(mp_read_json_ref "$expected") || { mp_die "expected claim object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$claim")" = "$session" ] || {
    mp_die "claim belongs to another session" 4
    return
  }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  generation_data=$(jq -cn --arg node "$node" --arg session "$session" --arg expected "$expected" \
    '{node:$node,session:$session,expected:$expected}')
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    new_generation=$(mp_generation_oid "$run" "$generation_oid" release-claim "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}delete $claim_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before claim release" 4; return; }
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$expected" ] || {
      mp_die "claim changed before release" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_slot_acquire() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run slot-acquire RUN_ID writer|integration NODE|@target --session ID --harness codex|claude [--expected-owner OBJECT_ID]" 2
    return
  fi
  local run=$1 kind=$2 node=$3 session='' harness='' expected_owner=''
  local seen_session=0 seen_harness=0 seen_expected_owner=0
  shift 3
  mp_validate_run_id "$run" || return
  case "$kind" in writer|integration) ;; *) mp_die "slot kind must be writer or integration" 2; return ;; esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2; seen_harness=1; shift 2 ;;
      --expected-owner)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected_owner" -eq 0 ] || { mp_die "duplicate --expected-owner" 2; return; }
        expected_owner=$2; seen_expected_owner=1; shift 2 ;;
      *) mp_die "unknown slot-acquire option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local manifest limit scope owner_oid='' identity claim ref slot_json slot_oid at slot
  local identity_ref identity_oid slot_ref generation_ref generation_oid new_generation
  local generation_data attempt=0 existing
  manifest=$(mp_manifest_json "$run") || { mp_die "run does not exist: $run" 3; return; }
  if [ "$kind" = writer ]; then limit=$(jq -r '.writer_limit' <<<"$manifest")
  else limit=$(jq -r '.integration_limit' <<<"$manifest")
  fi
  if [ "$node" = @target ]; then
    [ "$kind" = integration ] || { mp_die "writer @target is not allowed" 2; return; }
    [ "$seen_expected_owner" -eq 1 ] || { mp_die "@target requires --expected-owner" 2; return; }
    mp_object_id "$expected_owner" || { mp_die "expected owner must be an object ID" 2; return; }
    identity_ref=$(mp_run_ref "$run" owner) || return
    scope=target
  else
    [ "$seen_expected_owner" -eq 0 ] || { mp_die "--expected-owner is only valid for @target" 2; return; }
    mp_validate_node_path "$node" || return
    mp_read_json_ref "$(mp_run_ref "$run" "nodes/$node/brief")" >/dev/null || {
      mp_die "node brief does not exist" 3
      return
    }
    identity_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
    scope=node
  fi
  generation_ref=$(mp_generation_ref "$run") || return

  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    identity_oid=$(mp_read_ref "$identity_ref") || {
      if [ "$scope" = target ]; then mp_die "run owner is missing" 3
      else mp_die "node is not actively claimed" 4
      fi
      return
    }
    if [ "$scope" = target ]; then
      owner_oid=$identity_oid
      [ "$owner_oid" = "$expected_owner" ] || { mp_die "run owner changed" 4; return; }
      identity=$(mp_read_json_ref "$identity_oid") || { mp_die "owner object is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$identity")" = "$session" ] &&
        [ "$(jq -r '.harness' <<<"$identity")" = "$harness" ] || {
          mp_die "integration slot requires the elected owner" 4
          return
        }
    else
      claim=$(mp_read_json_ref "$identity_oid") || { mp_die "active node claim is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$claim")" = "$session" ] &&
        [ "$(jq -r '.harness' <<<"$claim")" = "$harness" ] || {
          mp_die "slot requires the active node claimant" 4
          return
        }
    fi

    while IFS= read -r ref; do
      existing=$(mp_read_json_ref "$ref") || { mp_die "active slot is malformed: $ref" 3; return; }
      if [ "$scope" = node ] && [ "$(jq -r '.scope' <<<"$existing")" = node ] &&
         [ "$(jq -r '.node' <<<"$existing")" = "$node" ]; then
        mp_die "node already holds a $kind slot" 4
        return
      fi
      if [ "$scope" = target ] && [ "$(jq -r '.scope' <<<"$existing")" = target ]; then
        mp_die "target already holds an integration slot" 4
        return
      fi
    done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" "slots/$kind")/")

    slot=1
    while [ "$slot" -le "$limit" ] &&
          mp_read_ref "$(mp_run_ref "$run" "slots/$kind/$slot")" >/dev/null; do
      slot=$((slot + 1))
    done
    [ "$slot" -le "$limit" ] || { mp_die "no $kind slot available" 4; return; }
    at=$(mp_now)
    generation_data=$(jq -cn --arg kind "$kind" --arg scope "$scope" --arg node "$node" \
      --arg session "$session" --arg harness "$harness" --arg identity "$identity_oid" \
      --argjson slot "$slot" \
      '{kind:$kind,scope:$scope,node:$node,session:$session,harness:$harness,
        identity:$identity,slot:$slot}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" slot-acquire "$generation_data") || return
    if [ "$scope" = node ]; then
      slot_json=$(jq -cn --arg session "$session" --arg harness "$harness" \
        --arg node "$node" --arg kind "$kind" --argjson slot "$slot" --arg at "$at" \
        --arg generation "$new_generation" \
        '{session:$session,harness:$harness,scope:"node",node:$node,kind:$kind,
          slot:$slot,claimed_at:$at,generation:$generation}')
    else
      slot_json=$(jq -cn --arg session "$session" --arg harness "$harness" \
        --arg kind "$kind" --argjson slot "$slot" --arg at "$at" --arg owner_oid "$owner_oid" \
        --arg generation "$new_generation" \
        '{session:$session,harness:$harness,scope:"target",node:null,kind:$kind,
          slot:$slot,claimed_at:$at,owner_oid:$owner_oid,generation:$generation}')
    fi
    slot_oid=$(printf '%s\n' "$slot_json" | git hash-object -w --stdin)
    slot_ref=$(mp_run_ref "$run" "slots/$kind/$slot") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $identity_ref $identity_oid
create $slot_ref $slot_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s %s\n' "$slot" "$slot_oid"
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before slot creation" 4; return; }
    [ "$(mp_ref_oid_or_zero "$identity_ref")" = "$identity_oid" ] || {
      mp_die "slot authorization changed before creation" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_slot_release() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run slot-release RUN_ID writer|integration SLOT --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 kind=$2 slot=$3 session='' expected='' seen_session=0 seen_expected=0
  shift 3
  mp_validate_run_id "$run" || return
  case "$kind" in writer|integration) ;; *) mp_die "slot kind must be writer or integration" 2; return ;; esac
  mp_positive_integer "slot" "$slot" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown slot-release option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local manifest limit slot_json slot_ref generation_ref generation_oid new_generation
  local generation_data attempt=0
  manifest=$(mp_manifest_json "$run") || { mp_die "run does not exist: $run" 3; return; }
  if [ "$kind" = writer ]; then limit=$(jq -r '.writer_limit' <<<"$manifest")
  else limit=$(jq -r '.integration_limit' <<<"$manifest")
  fi
  [ "$slot" -le "$limit" ] || { mp_die "slot number exceeds the manifest limit" 2; return; }
  slot_json=$(mp_read_json_ref "$expected") || { mp_die "expected slot object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$slot_json")" = "$session" ] &&
    [ "$(jq -r '.kind' <<<"$slot_json")" = "$kind" ] &&
    [ "$(jq -r '.slot' <<<"$slot_json")" = "$slot" ] || {
      mp_die "slot object does not match the release request" 4
      return
    }
  slot_ref=$(mp_run_ref "$run" "slots/$kind/$slot") || return
  generation_ref=$(mp_generation_ref "$run") || return
  generation_data=$(jq -cn --arg kind "$kind" --argjson slot "$slot" \
    --arg session "$session" --arg expected "$expected" \
    '{kind:$kind,slot:$slot,session:$session,expected:$expected}')
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    new_generation=$(mp_generation_oid "$run" "$generation_oid" slot-release "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}delete $slot_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    mp_run_is_open "$run" || { mp_die "run started closing before slot release" 4; return; }
    [ "$(mp_ref_oid_or_zero "$slot_ref")" = "$expected" ] || {
      mp_die "slot changed before release" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_result_put() {
  if [ "$#" -lt 4 ]; then
    mp_die "usage: sdd-run result-put RUN_ID NODE RESULT.json EVIDENCE_DIR --session ID [--expected OBJECT_ID] [--redactions FILE] [--digest-only --summary TEXT]" 2
    return
  fi
  local run=$1 node=$2 result_file=$3 evidence_dir=$4
  local session='' expected='' redactions='' summary=''
  local seen_session=0 seen_expected=0 seen_redactions=0 digest_only=0 seen_summary=0
  shift 4
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  [ -f "$result_file" ] && [ ! -L "$result_file" ] || {
    mp_die "result must be a non-symlink regular file" 2
    return
  }
  [ -d "$evidence_dir" ] && [ ! -L "$evidence_dir" ] || {
    mp_die "evidence directory must be a non-symlink directory" 2
    return
  }
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      --redactions)
        mp_need_value "$#" "$1" || return
        [ "$seen_redactions" -eq 0 ] || { mp_die "duplicate --redactions" 2; return; }
        redactions=$2; seen_redactions=1; shift 2 ;;
      --digest-only)
        [ "$digest_only" -eq 0 ] || { mp_die "duplicate --digest-only" 2; return; }
        digest_only=1; shift ;;
      --summary)
        mp_need_value "$#" "$1" || return
        [ "$seen_summary" -eq 0 ] || { mp_die "duplicate --summary" 2; return; }
        summary=$2; seen_summary=1; shift 2 ;;
      *) mp_die "unknown result-put option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  mp_validate_session_id "$session" || return
  if [ "$seen_expected" -eq 1 ]; then
    mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  fi
  if [ "$seen_redactions" -eq 1 ]; then
    [ -f "$redactions" ] && [ ! -L "$redactions" ] || {
      mp_die "redactions must be a non-symlink regular file" 2
      return
    }
  fi
  if [ "$digest_only" -eq 1 ]; then
    [ "$seen_summary" -eq 1 ] && [ -n "$summary" ] || {
      mp_die "--digest-only requires a nonempty --summary" 2
      return
    }
  elif [ "$seen_summary" -eq 1 ]; then
    mp_die "--summary requires --digest-only" 2
    return
  fi

  local temp canonical result brief_ref brief_oid brief base head branch branch_ref
  local claim_ref claim_oid claim result_ref generation_ref result_blob evidence_tree result_tree
  local names_file entries_file redactions_file summary_source summary_sanitized summary_text
  temp=$(mktemp -d) || { mp_die "could not create result workspace" 3; return; }
  MP_RESULT_TEMP=$temp
  trap 'rm -rf "$MP_RESULT_TEMP"' EXIT HUP INT TERM
  canonical="$temp/result.json"
  jq -ce . "$result_file" > "$canonical" || { mp_die "result is not valid JSON" 2; return; }
  result=$(cat "$canonical")
  jq -e \
    '(.status == "done" or .status == "blocked") and
     (.run_id | type == "string") and
     (.node | type == "string") and
     (.base | type == "string") and
     (.head | type == "string") and
     (.branch | type == "string") and
     ((.verification | type) == "array" and all(.verification[];
        ((.command | type) == "string" and (.command | length) > 0) and
        ((.exit_code | type) == "number" and
         (.exit_code | floor) == .exit_code) and
        ((.evidence_path | type) == "string" and
         (.evidence_path | startswith("evidence/"))))) and
     (.unresolved | type == "array" and all(.[]; type == "string")) and
     (if .status == "done"
        then ((.verification | length) > 0 and
          all(.verification[]; .exit_code == 0)) and
          (.unresolved | length == 0)
        else (.unresolved | length > 0)
      end)' "$canonical" >/dev/null || {
    mp_die "result does not match the result contract" 2
    return
  }
  [ "$(jq -r '.run_id' <<<"$result")" = "$run" ] || {
    mp_die "result run_id does not match command" 2
    return
  }
  [ "$(jq -r '.node' <<<"$result")" = "$node" ] || {
    mp_die "result node does not match command" 2
    return
  }
  mp_contains_credential "$canonical" && {
    mp_die "result contains a credential-like value" 3
    return
  }

  brief_ref=$(mp_run_ref "$run" "nodes/$node/brief") || return
  brief_oid=$(mp_read_ref "$brief_ref") || { mp_die "node brief does not exist" 3; return; }
  brief=$(mp_read_json_ref "$brief_oid") || { mp_die "node brief is malformed" 3; return; }
  base=$(jq -r '.base' <<<"$result")
  head=$(jq -r '.head' <<<"$result")
  branch=$(jq -r '.branch' <<<"$result")
  [ "$(git cat-file -t "$base" 2>/dev/null || true)" = commit ] || {
    mp_die "result base must name a commit object" 2
    return
  }
  [ "$(git cat-file -t "$head" 2>/dev/null || true)" = commit ] || {
    mp_die "result head must name a commit object" 2
    return
  }
  [ "$base" = "$(jq -r '.base' <<<"$brief")" ] || {
    mp_die "result base does not match the immutable brief" 4
    return
  }
  [ "$branch" = "$(jq -r '.branch' <<<"$brief")" ] || {
    mp_die "result branch does not match the immutable brief" 4
    return
  }
  branch_ref="refs/heads/$branch"
  [ "$(mp_read_ref "$branch_ref" || true)" = "$head" ] || {
    mp_die "result head does not match the node branch" 4
    return
  }
  git merge-base --is-ancestor "$base" "$head" 2>/dev/null || {
    mp_die "result head does not descend from the brief base" 4
    return
  }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  claim_oid=$(mp_read_ref "$claim_ref") || { mp_die "node is not actively claimed" 4; return; }
  claim=$(mp_read_json_ref "$claim_oid") || { mp_die "active node claim is malformed" 3; return; }
  [ "$(jq -r '.session' <<<"$claim")" = "$session" ] || {
    mp_die "result requires the active node claimant" 4
    return
  }

  redactions_file="$temp/redactions"
  if [ "$seen_redactions" -eq 1 ]; then
    cp "$redactions" "$redactions_file" || { mp_die "could not snapshot redactions" 3; return; }
  else
    : > "$redactions_file"
  fi
  if [ "$digest_only" -eq 1 ]; then
    [ "$(printf '%s' "$summary" | wc -c | tr -d ' ')" -le 1024 ] || {
      mp_die "digest summary exceeds 1 KiB" 3
      return
    }
    summary_source="$temp/summary-source"
    summary_sanitized="$temp/summary-sanitized"
    printf '%s\n' "$summary" > "$summary_source"
    mp_redact_file "$redactions_file" "$summary_source" "$summary_sanitized" || {
      mp_die "could not redact digest summary" 3
      return
    }
    [ "$(wc -c < "$summary_sanitized" | tr -d ' ')" -le 1024 ] || {
      mp_die "redacted digest summary exceeds 1 KiB" 3
      return
    }
    mp_contains_credential "$summary_sanitized" && {
      mp_die "digest summary contains a credential-like value" 3
      return
    }
    summary_text=$(cat "$summary_sanitized")
  fi

  names_file="$temp/evidence-names"
  entries_file="$temp/evidence-entries"
  jq -r '.verification[].evidence_path' "$canonical" | LC_ALL=C sort > "$names_file"
  [ "$(jq '[.verification[].evidence_path] | length' "$canonical")" = \
    "$(jq '[.verification[].evidence_path] | unique | length' "$canonical")" ] || {
    mp_die "result contains duplicate evidence paths" 2
    return
  }
  : > "$entries_file"
  local evidence_path filename source sanitized blob bytes total=0 digest
  while IFS= read -r evidence_path; do
    [ -n "$evidence_path" ] || continue
    case "$evidence_path" in evidence/*) filename=${evidence_path#evidence/} ;; *) filename='' ;; esac
    [[ "$filename" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || {
      mp_die "evidence paths must have the form evidence/FILENAME" 2
      return
    }
    source="$evidence_dir/$filename"
    [ -f "$source" ] && [ ! -L "$source" ] || {
      mp_die "evidence source must be a non-symlink regular file: $filename" 2
      return
    }
    sanitized="$temp/sanitized-$filename"
    if [ "$digest_only" -eq 1 ]; then
      bytes=$(wc -c < "$source" | tr -d ' ')
      digest=$(git hash-object --no-filters "$source") || {
        mp_die "could not digest evidence: $filename" 3
        return
      }
      jq -cn --arg summary "$summary_text" --arg git_blob_oid "$digest" \
        --argjson bytes "$bytes" \
        '{summary:$summary,git_blob_oid:$git_blob_oid,bytes:$bytes}' > "$sanitized"
    else
      mp_redact_file "$redactions_file" "$source" "$sanitized" || {
        mp_die "could not redact evidence: $filename" 3
        return
      }
    fi
    mp_contains_credential "$sanitized" && {
      mp_die "evidence contains a credential-like value after redaction: $filename" 3
      return
    }
    bytes=$(wc -c < "$sanitized" | tr -d ' ')
    [ "$bytes" -le 65536 ] || { mp_die "evidence file exceeds 64 KiB: $filename" 3; return; }
    total=$((total + bytes))
    [ "$total" -le 262144 ] || { mp_die "evidence set exceeds 256 KiB" 3; return; }
    blob=$(git hash-object -w -- "$sanitized") || { mp_die "could not hash evidence" 3; return; }
    printf '100644 blob %s\t%s\n' "$blob" "$filename" >> "$entries_file"
  done < "$names_file"

  local candidate candidate_name referenced
  for candidate in "$evidence_dir"/* "$evidence_dir"/.[!.]* "$evidence_dir"/..?*; do
    [ -e "$candidate" ] || [ -L "$candidate" ] || continue
    candidate_name=${candidate##*/}
    [[ "$candidate_name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || {
      mp_die "evidence directory contains an invalid filename" 2
      return
    }
    referenced="evidence/$candidate_name"
    LC_ALL=C grep -Fqx "$referenced" "$names_file" || {
      mp_die "evidence directory contains an unreferenced file: $candidate_name" 2
      return
    }
  done

  result_blob=$(jq -ce . "$canonical" | git hash-object -w --stdin) || {
    mp_die "could not hash result" 3
    return
  }
  evidence_tree=$(git mktree < "$entries_file") || { mp_die "could not build evidence tree" 3; return; }
  result_tree=$(
    {
      printf '100644 blob %s\tresult.json\n' "$result_blob"
      printf '040000 tree %s\tevidence\n' "$evidence_tree"
    } | git mktree
  ) || { mp_die "could not build result tree" 3; return; }

  result_ref=$(mp_run_ref "$run" "nodes/$node/result") || return
  generation_ref=$(mp_generation_ref "$run") || return
  local generation_oid new_generation generation_data existing existing_json attempt=0
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    existing=$(mp_ref_oid_or_zero "$result_ref")
    if [ "$existing" = "$(mp_zero_oid)" ]; then
      [ "$seen_expected" -eq 0 ] || { mp_die "--expected requires an existing blocked result" 4; return; }
    else
      existing_json=$(mp_read_result_json "$existing") || { mp_die "existing result is malformed" 3; return; }
      jq -e '.status == "done"' >/dev/null <<<"$existing_json" && {
        mp_die "done results are immutable" 4
        return
      }
      jq -e '.status == "blocked"' >/dev/null <<<"$existing_json" || {
        mp_die "existing result has an unsupported status" 3
        return
      }
      [ "$seen_expected" -eq 1 ] && [ "$expected" = "$existing" ] || {
        mp_die "blocked result replacement requires its exact --expected object" 4
        return
      }
    fi
    generation_data=$(jq -cn --arg node "$node" --arg session "$session" \
      --arg claim "$claim_oid" --arg previous "$existing" --arg result "$result_tree" \
      '{node:$node,session:$session,claim:$claim,previous_result:$previous,result:$result}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" result-put "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $brief_ref $brief_oid
verify $claim_ref $claim_oid
verify $branch_ref $head
update $result_ref $result_tree $existing
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s\n' "$result_tree"
      return
    fi
    mp_report_native_ref_locks "$brief_ref" "$claim_ref" "$branch_ref" "$result_ref" \
      "$generation_ref" "$MP_OPEN_CLOSING_REF" "$MP_OPEN_CLOSED_REF" && return 4
    mp_run_is_open "$run" || { mp_die "run started closing before result update" 4; return; }
    [ "$(mp_ref_oid_or_zero "$brief_ref")" = "$brief_oid" ] || { mp_die "node brief changed before result" 4; return; }
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$claim_oid" ] || { mp_die "node claim changed before result" 4; return; }
    [ "$(mp_ref_oid_or_zero "$branch_ref")" = "$head" ] || { mp_die "node branch changed before result" 4; return; }
    [ "$(mp_ref_oid_or_zero "$result_ref")" = "$existing" ] || { mp_die "node result changed before update" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_status() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run status RUN_ID [--stale-after SECONDS]" 2
    return
  fi
  local run=$1 stale_after=900 seen_stale=0
  shift
  mp_validate_run_id "$run" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --stale-after)
        mp_need_value "$#" "$1" || return
        [ "$seen_stale" -eq 0 ] || { mp_die "duplicate --stale-after" 2; return; }
        stale_after=$2; seen_stale=1; shift 2 ;;
      *) mp_die "unknown status option: $1" 2; return ;;
    esac
  done
  [[ "$stale_after" =~ ^[0-9]+$ ]] || { mp_die "stale-after must be a nonnegative integer" 2; return; }

  local prefix refs manifest_ref manifest_oid manifest owner_ref owner_oid owner=null now
  local closed_ref closed_oid closed=null nodes_file slots_file ref oid suffix node
  local brief_oid claim_ref claim_oid claim result_ref result_oid result kind slot slot_json
  local node_json slot_output generation_ref generation_before generation_after status_json attempt=0
  prefix="refs/megapowers/runs/$run/"
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
  generation_before=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
  owner=null
  closed=null
  refs=$(LC_ALL=C git for-each-ref --format='%(refname) %(objectname)' "$prefix")
  [ -n "$refs" ] || { mp_die "run does not exist: $run" 3; return; }
  manifest_ref=$(mp_run_ref "$run" manifest) || return
  manifest_oid=$(mp_read_ref "$manifest_ref") || { mp_die "run manifest is missing" 3; return; }
  manifest=$(mp_read_json_ref "$manifest_oid") || { mp_die "run manifest is malformed" 3; return; }
  now=$(mp_now)
  owner_ref=$(mp_run_ref "$run" owner) || return
  if owner_oid=$(mp_read_ref "$owner_ref"); then
    owner=$(mp_read_json_ref "$owner_oid") || { mp_die "run owner is malformed" 3; return; }
    owner=$(jq -c --arg oid "$owner_oid" --arg now "$now" --argjson seconds "$stale_after" '
      def stale($now; $seconds):
        (($now | fromdateiso8601) - (.last_activity | fromdateiso8601)) > $seconds;
      . as $value |
      $value + {object_id:$oid,stale:($value | stale($now; $seconds))}' <<<"$owner") || {
      mp_die "run owner has an invalid activity timestamp" 3
      return
    }
  fi
  closed_ref=$(mp_run_ref "$run" closed) || return
  if closed_oid=$(mp_read_ref "$closed_ref"); then
    closed=$(mp_read_json_ref "$closed_oid") || { mp_die "run closure is malformed" 3; return; }
    closed=$(jq -c --arg oid "$closed_oid" '. + {object_id:$oid}' <<<"$closed")
  fi

  nodes_file=$(mktemp) || { mp_die "could not create status workspace" 3; return; }
  slots_file=$(mktemp) || { rm -f "$nodes_file"; mp_die "could not create status workspace" 3; return; }
  MP_STATUS_NODES=$nodes_file
  MP_STATUS_SLOTS=$slots_file
  trap 'rm -f "$MP_STATUS_NODES" "$MP_STATUS_SLOTS"' EXIT HUP INT TERM
  : > "$nodes_file"
  : > "$slots_file"
  while IFS=' ' read -r ref oid; do
    [ -n "$ref" ] || continue
    suffix=${ref#"$prefix"}
    case "$suffix" in
      nodes/*/brief)
        node=${suffix#nodes/}
        node=${node%/brief}
        brief_oid=$oid
        claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
        claim=null
        if claim_oid=$(mp_read_ref "$claim_ref"); then
          claim=$(mp_read_json_ref "$claim_oid") || { mp_die "node claim is malformed: $node" 3; return; }
          claim=$(jq -c --arg oid "$claim_oid" --arg now "$now" --argjson seconds "$stale_after" '
            def stale($now; $seconds):
              (($now | fromdateiso8601) - (.last_activity | fromdateiso8601)) > $seconds;
            . as $value |
            $value + {object_id:$oid,stale:($value | stale($now; $seconds))}' <<<"$claim") || {
            mp_die "node claim has an invalid activity timestamp: $node" 3
            return
          }
        fi
        result_ref=$(mp_run_ref "$run" "nodes/$node/result") || return
        result=null
        if result_oid=$(mp_read_ref "$result_ref"); then
          result=$(mp_read_result_json "$result_oid") || { mp_die "node result is malformed: $node" 3; return; }
          result=$(jq -c --arg oid "$result_oid" '. + {object_id:$oid}' <<<"$result")
        fi
        node_json=$(jq -cn --arg node "$node" --arg brief_oid "$brief_oid" \
          --argjson claim "$claim" --argjson result "$result" \
          '{node:$node,brief_oid:$brief_oid,claim:$claim,result:$result}')
        printf '%s\n' "$node_json" >> "$nodes_file"
        ;;
      slots/writer/*|slots/integration/*)
        kind=${suffix#slots/}; kind=${kind%%/*}
        slot=${suffix##*/}
        slot_json=$(mp_read_json_ref "$oid") || { mp_die "active slot is malformed: $kind/$slot" 3; return; }
        slot_output=$(jq -c --arg oid "$oid" --arg now "$now" --argjson seconds "$stale_after" '
          def stale($now; $seconds):
            (($now | fromdateiso8601) - (.last_activity | fromdateiso8601)) > $seconds;
          . as $value |
          ($value + {last_activity:($value.last_activity // $value.claimed_at)}) as $dated |
          $value + {object_id:$oid,stale:($dated | stale($now; $seconds))}' <<<"$slot_json") || {
          mp_die "active slot has an invalid activity timestamp: $kind/$slot" 3
          return
        }
        printf '%s\n' "$slot_output" >> "$slots_file"
        ;;
    esac
  done <<<"$refs"
  status_json=$(jq -cn --arg run_id "$run" --argjson manifest "$manifest" --argjson owner "$owner" \
    --slurpfile nodes "$nodes_file" --slurpfile slots "$slots_file" --argjson closed "$closed" \
    '{run_id:$run_id,manifest:$manifest,owner:$owner,nodes:$nodes,slots:$slots,closed:$closed}') || return
  generation_after=$(mp_read_ref "$generation_ref" || true)
  rm -f "$nodes_file" "$slots_file"
  trap - EXIT HUP INT TERM
  if [ "$generation_before" = "$generation_after" ]; then
    printf '%s\n' "$status_json"
    return
  fi
  attempt=$((attempt + 1))
  mp_generation_retry "$attempt" || return
  done
}

cmd_owner_heartbeat() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run owner-heartbeat RUN_ID --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 session='' expected='' seen_session=0 seen_expected=0
  shift
  mp_validate_run_id "$run" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown owner-heartbeat option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local owner owner_ref generation_ref generation_oid new_generation new_oid at data attempt=0
  owner=$(mp_read_json_ref "$expected") || { mp_die "expected owner object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$owner")" = "$session" ] || { mp_die "owner belongs to another session" 4; return; }
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    at=$(mp_now)
    data=$(jq -cn --arg session "$session" --arg expected "$expected" --arg at "$at" \
      '{session:$session,expected:$expected,last_activity:$at}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" owner-heartbeat "$data") || return
    new_oid=$(printf '%s\n' "$owner" | jq -c --arg at "$at" --arg generation "$new_generation" \
      '.last_activity=$at | .generation=$generation' | git hash-object -w --stdin) || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}update $owner_ref $new_oid $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s\n' "$new_oid"
      return
    fi
    mp_report_native_ref_locks "$owner_ref" "$generation_ref" \
      "$MP_OPEN_CLOSING_REF" "$MP_OPEN_CLOSED_REF" && return 4
    mp_run_is_open "$run" || { mp_die "run started closing before owner heartbeat" 4; return; }
    [ "$(mp_ref_oid_or_zero "$owner_ref")" = "$expected" ] || { mp_die "owner changed before heartbeat" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_recover_claim() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run recover-claim RUN_ID NODE --owner-session ID --expected OBJECT_ID --confirmed-inactive" 2
    return
  fi
  local run=$1 node=$2 owner_session='' expected=''
  local seen_owner=0 seen_expected=0 confirmed=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --owner-session)
        mp_need_value "$#" "$1" || return
        [ "$seen_owner" -eq 0 ] || { mp_die "duplicate --owner-session" 2; return; }
        owner_session=$2; seen_owner=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      --confirmed-inactive)
        [ "$confirmed" -eq 0 ] || { mp_die "duplicate --confirmed-inactive" 2; return; }
        confirmed=1; shift ;;
      *) mp_die "unknown recover-claim option: $1" 2; return ;;
    esac
  done
  [ "$seen_owner" -eq 1 ] || { mp_die "missing --owner-session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  [ "$confirmed" -eq 1 ] || { mp_die "--confirmed-inactive is required" 2; return; }
  mp_validate_session_id "$owner_session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local claim claim_ref owner_ref owner_oid owner generation_ref generation_oid new_generation data attempt=0
  claim=$(mp_read_json_ref "$expected") || { mp_die "expected claim object is missing" 3; return; }
  [ "$(jq -r '.node' <<<"$claim")" = "$node" ] || { mp_die "claim object does not match the node" 4; return; }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    owner_oid=$(mp_read_ref "$owner_ref") || { mp_die "run owner is missing" 3; return; }
    owner=$(mp_read_json_ref "$owner_oid") || { mp_die "run owner is malformed" 3; return; }
    [ "$(jq -r '.session' <<<"$owner")" = "$owner_session" ] || { mp_die "recovery requires the current owner session" 4; return; }
    data=$(jq -cn --arg node "$node" --arg owner "$owner_oid" --arg expected "$expected" \
      '{node:$node,owner:$owner,expected:$expected}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" recover-claim "$data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $owner_ref $owner_oid
delete $claim_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    mp_report_native_ref_locks "$owner_ref" "$claim_ref" "$generation_ref" \
      "$MP_OPEN_CLOSING_REF" "$MP_OPEN_CLOSED_REF" && return 4
    mp_run_is_open "$run" || { mp_die "run started closing before claim recovery" 4; return; }
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$expected" ] || { mp_die "claim changed before recovery" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_recover_slot() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run recover-slot RUN_ID writer|integration SLOT --owner-session ID --expected OBJECT_ID --confirmed-inactive" 2
    return
  fi
  local run=$1 kind=$2 slot=$3 owner_session='' expected=''
  local seen_owner=0 seen_expected=0 confirmed=0
  shift 3
  mp_validate_run_id "$run" || return
  case "$kind" in writer|integration) ;; *) mp_die "slot kind must be writer or integration" 2; return ;; esac
  mp_positive_integer "slot" "$slot" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --owner-session)
        mp_need_value "$#" "$1" || return
        [ "$seen_owner" -eq 0 ] || { mp_die "duplicate --owner-session" 2; return; }
        owner_session=$2; seen_owner=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      --confirmed-inactive)
        [ "$confirmed" -eq 0 ] || { mp_die "duplicate --confirmed-inactive" 2; return; }
        confirmed=1; shift ;;
      *) mp_die "unknown recover-slot option: $1" 2; return ;;
    esac
  done
  [ "$seen_owner" -eq 1 ] || { mp_die "missing --owner-session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  [ "$confirmed" -eq 1 ] || { mp_die "--confirmed-inactive is required" 2; return; }
  mp_validate_session_id "$owner_session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local slot_json slot_ref owner_ref owner_oid owner generation_ref generation_oid new_generation data attempt=0
  slot_json=$(mp_read_json_ref "$expected") || { mp_die "expected slot object is missing" 3; return; }
  [ "$(jq -r '.kind' <<<"$slot_json")" = "$kind" ] &&
    [ "$(jq -r '.slot' <<<"$slot_json")" = "$slot" ] || {
      mp_die "slot object does not match the recovery request" 4
      return
    }
  slot_ref=$(mp_run_ref "$run" "slots/$kind/$slot") || return
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    owner_oid=$(mp_read_ref "$owner_ref") || { mp_die "run owner is missing" 3; return; }
    owner=$(mp_read_json_ref "$owner_oid") || { mp_die "run owner is malformed" 3; return; }
    [ "$(jq -r '.session' <<<"$owner")" = "$owner_session" ] || { mp_die "recovery requires the current owner session" 4; return; }
    data=$(jq -cn --arg kind "$kind" --argjson slot "$slot" --arg owner "$owner_oid" \
      --arg expected "$expected" '{kind:$kind,slot:$slot,owner:$owner,expected:$expected}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" recover-slot "$data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}verify $owner_ref $owner_oid
delete $slot_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    mp_report_native_ref_locks "$owner_ref" "$slot_ref" "$generation_ref" \
      "$MP_OPEN_CLOSING_REF" "$MP_OPEN_CLOSED_REF" && return 4
    mp_run_is_open "$run" || { mp_die "run started closing before slot recovery" 4; return; }
    [ "$(mp_ref_oid_or_zero "$slot_ref")" = "$expected" ] || { mp_die "slot changed before recovery" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_recover_owner() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run recover-owner RUN_ID --session NEW_ID --harness codex|claude --expected OLD_OBJECT_ID --confirmed-inactive" 2
    return
  fi
  local run=$1 session='' harness='' expected=''
  local seen_session=0 seen_harness=0 seen_expected=0 confirmed=0
  shift
  mp_validate_run_id "$run" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2; seen_harness=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      --confirmed-inactive)
        [ "$confirmed" -eq 0 ] || { mp_die "duplicate --confirmed-inactive" 2; return; }
        confirmed=1; shift ;;
      *) mp_die "unknown recover-owner option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  [ "$confirmed" -eq 1 ] || { mp_die "--confirmed-inactive is required" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local previous owner_ref generation_ref generation_oid new_generation new_oid at data attempt=0
  previous=$(mp_read_json_ref "$expected") || { mp_die "expected owner object is missing" 3; return; }
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    mp_require_run_open "$run" || return
    at=$(mp_now)
    data=$(jq -cn --arg session "$session" --arg harness "$harness" --arg expected "$expected" \
      '{session:$session,harness:$harness,expected:$expected}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" recover-owner "$data") || return
    new_oid=$(jq -cn --arg session "$session" --arg harness "$harness" --arg at "$at" \
      --arg previous_claimed_at "$(jq -r '.claimed_at' <<<"$previous")" \
      --arg generation "$new_generation" \
      '{session:$session,harness:$harness,claimed_at:$at,last_activity:$at,
        previous_claimed_at:$previous_claimed_at,generation:$generation}' |
      git hash-object -w --stdin) || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
${MP_OPEN_STATE_VERIFICATIONS}update $owner_ref $new_oid $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s\n' "$new_oid"
      return
    fi
    mp_report_native_ref_locks "$owner_ref" "$generation_ref" \
      "$MP_OPEN_CLOSING_REF" "$MP_OPEN_CLOSED_REF" && return 4
    mp_run_is_open "$run" || { mp_die "run started closing before owner recovery" 4; return; }
    [ "$(mp_ref_oid_or_zero "$owner_ref")" = "$expected" ] || { mp_die "owner changed before recovery" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_close() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run close RUN_ID --owner-session ID --expected OWNER_OBJECT_ID" 2
    return
  fi
  local run=$1 owner_session='' expected='' seen_owner=0 seen_expected=0
  shift
  mp_validate_run_id "$run" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --owner-session)
        mp_need_value "$#" "$1" || return
        [ "$seen_owner" -eq 0 ] || { mp_die "duplicate --owner-session" 2; return; }
        owner_session=$2; seen_owner=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown close option: $1" 2; return ;;
    esac
  done
  [ "$seen_owner" -eq 1 ] || { mp_die "missing --owner-session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$owner_session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }

  local owner owner_ref manifest target_branch target_ref closed_ref closing_ref generation_ref
  local generation_oid new_generation target_head closed_at closed_oid data attempt=0 zero
  local refs ref closing_oid closing barrier_oid barrier_at worktree_status rollback_generation
  owner=$(mp_read_json_ref "$expected") || { mp_die "expected owner object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$owner")" = "$owner_session" ] || {
    mp_die "owner belongs to another session" 4
    return
  }
  manifest=$(mp_manifest_json "$run") || { mp_die "run manifest is missing or malformed" 3; return; }
  target_branch=$(jq -r '.target_branch' <<<"$manifest")
  target_ref="refs/heads/$target_branch"
  owner_ref=$(mp_run_ref "$run" owner) || return
  closed_ref=$(mp_run_ref "$run" closed) || return
  closing_ref=$(mp_run_ref "$run" closing) || return
  generation_ref=$(mp_generation_ref "$run") || return
  zero=$(mp_zero_oid) || return

  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    [ "$(mp_ref_oid_or_zero "$owner_ref")" = "$expected" ] || {
      mp_die "run owner changed before closure" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$closed_ref")" = "$zero" ] || {
      mp_die "run is already closed" 4
      return
    }
    target_head=$(mp_read_ref "$target_ref") || { mp_die "target branch is missing" 3; return; }
    mp_prepare_close_snapshot "$run" "$manifest" "$target_head" || return

    refs=$(LC_ALL=C git for-each-ref --format='%(refname)' \
      "$(mp_run_ref "$run" nodes)/" "$(mp_run_ref "$run" slots)/")
    while IFS= read -r ref; do
      [ -n "$ref" ] || continue
      case "$ref" in
        */claim|*/slots/writer/*|*/slots/integration/*)
          mp_die "active claims or slots prevent closure" 4
          return
          ;;
      esac
    done <<<"$refs"

    closing_oid=$(mp_ref_oid_or_zero "$closing_ref")
    if [ "$closing_oid" != "$zero" ]; then
      closing=$(mp_read_json_ref "$closing_oid") || {
        mp_die "run closing barrier is malformed" 3
        return
      }
      jq -e --arg owner "$expected" --arg session "$owner_session" \
        --arg target_branch "$target_branch" --arg target_head "$target_head" \
        '.version == 1 and .owner_object_id == $owner and .closed_by == $session and
         .target_branch == $target_branch and .target_head == $target_head' \
        >/dev/null <<<"$closing" || {
        mp_die "run is closing under a different closure snapshot" 4
        return
      }
      barrier_oid=$closing_oid
      break
    fi

    if mp_run_branch_worktrees_clear "$run"; then
      :
    else
      worktree_status=$?
      [ "$worktree_status" -eq 1 ] && {
        mp_die "a run branch is checked out in a worktree" 4
        return
      }
      mp_die "could not inspect worktrees" 3
      return
    fi
    barrier_at=$(mp_now)
    barrier_oid=$(jq -cn --arg owner_object_id "$expected" --arg closed_by "$owner_session" \
      --arg target_branch "$target_branch" --arg target_head "$target_head" \
      --arg started_at "$barrier_at" \
      '{version:1,owner_object_id:$owner_object_id,closed_by:$closed_by,
        target_branch:$target_branch,target_head:$target_head,started_at:$started_at}' |
      git hash-object -w --stdin) || return
    data=$(jq -cn --arg owner "$expected" --arg closing "$barrier_oid" \
      --arg target_head "$target_head" \
      '{owner:$owner,closing:$closing,target_head:$target_head}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" close-begin "$data") || return
    mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
      "$owner_ref" "$generation_ref" && return 4
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $target_ref $target_head
${MP_CLOSE_RESULT_VERIFICATIONS}verify $closed_ref $zero
verify $owner_ref $expected
create $closing_ref $barrier_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      break
    fi
    mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
      "$owner_ref" "$generation_ref" && return 4
    [ "$(mp_ref_oid_or_zero "$owner_ref")" = "$expected" ] || {
      mp_die "run owner changed before closure" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$target_ref")" = "$target_head" ] || {
      mp_die "target branch changed before closure" 4
      return
    }
    mp_verifications_current "$MP_CLOSE_RESULT_VERIFICATIONS" || {
      mp_die "node result changed before closure" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done

  if mp_run_branch_worktrees_clear "$run"; then
    :
  else
    worktree_status=$?
    [ "$worktree_status" -eq 1 ] && {
      mp_die "a run branch appeared during closure; the run remains closing" 4
      return
    }
    mp_die "could not inspect worktrees" 3
    return
  fi
  [ "$(mp_ref_oid_or_zero "$target_ref")" = "$target_head" ] || {
    mp_die "target branch changed while the run was closing" 4
    return
  }
  mp_prepare_close_snapshot "$run" "$manifest" "$target_head" || return
  generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
  closed_at=$(mp_now)
  closed_oid=$(jq -cn --arg closed_by "$owner_session" --arg target_branch "$target_branch" \
    --arg target_head "$target_head" --arg closed_at "$closed_at" \
    '{closed_by:$closed_by,target_branch:$target_branch,target_head:$target_head,closed_at:$closed_at}' |
    git hash-object -w --stdin) || return
  data=$(jq -cn --arg owner "$expected" --arg closing "$barrier_oid" --arg closed "$closed_oid" \
    --arg target_head "$target_head" \
    '{owner:$owner,closing:$closing,closed:$closed,target_head:$target_head}')
  new_generation=$(mp_generation_oid "$run" "$generation_oid" close "$data") || return
  mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
    "$owner_ref" "$generation_ref" && return 4
  if ! git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $target_ref $target_head
${MP_CLOSE_RESULT_VERIFICATIONS}create $closed_ref $closed_oid
delete $owner_ref $expected
delete $closing_ref $barrier_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
  then
    mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
      "$owner_ref" "$generation_ref" && return 4
    mp_die "closure snapshot changed before finalization; the run remains closing" 4
    return
  fi

  if mp_run_branch_worktrees_clear "$run"; then
    printf '%s\n' "$closed_oid"
    return
  fi
  worktree_status=$?
  [ "$worktree_status" -eq 1 ] || {
    mp_die "could not inspect worktrees after closure" 3
    return
  }
  data=$(jq -cn --arg closed "$closed_oid" --arg closing "$barrier_oid" \
    '{closed:$closed,closing:$closing}')
  rollback_generation=$(mp_generation_oid "$run" "$new_generation" close-rollback "$data") || return
  mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
    "$owner_ref" "$generation_ref" && return 4
  if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $target_ref $target_head
${MP_CLOSE_RESULT_VERIFICATIONS}delete $closed_ref $closed_oid
create $closing_ref $barrier_oid
create $owner_ref $expected
update $generation_ref $rollback_generation $new_generation
prepare
commit
EOF
  then
    mp_die "a run branch appeared during closure; closure was rolled back and the run remains closing" 4
    return
  fi
  mp_report_close_native_locks "$target_ref" "$closing_ref" "$closed_ref" \
    "$owner_ref" "$generation_ref" && return 4
  mp_die "a run worktree exists and closure rollback requires manual recovery" 3
}
cmd_cleanup() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run cleanup RUN_ID --expected-closed OBJECT_ID --confirmed" 2
    return
  fi
  local run=$1 expected='' seen_expected=0 confirmed=0
  shift
  mp_validate_run_id "$run" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --expected-closed)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected-closed" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      --confirmed)
        [ "$confirmed" -eq 0 ] || { mp_die "duplicate --confirmed" 2; return; }
        confirmed=1; shift ;;
      *) mp_die "unknown cleanup option: $1" 2; return ;;
    esac
  done
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected-closed" 2; return; }
  [ "$confirmed" -eq 1 ] || { mp_die "--confirmed is required" 2; return; }
  mp_object_id "$expected" || { mp_die "expected closed object must be an object ID" 2; return; }

  local closed_ref generation_ref closing_ref closed_oid generation_oid worktree_status
  local refs post_refs ref oid current commands restore_commands restored=1
  local -a ref_names=()
  closed_ref=$(mp_run_ref "$run" closed) || return
  closing_ref=$(mp_run_ref "$run" closing) || return
  generation_ref=$(mp_generation_ref "$run") || return
  closed_oid=$(mp_read_ref "$closed_ref") || { mp_die "run is not closed" 3; return; }
  [ "$closed_oid" = "$expected" ] || { mp_die "closed object changed before cleanup" 4; return; }
  mp_read_json_ref "$closed_oid" >/dev/null || { mp_die "run closure is malformed" 3; return; }
  [ "$(mp_ref_oid_or_zero "$closing_ref")" = "$(mp_zero_oid)" ] || {
    mp_die "run is still closing" 4
    return
  }
  generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }

  if mp_cleanup_worktrees_clear "$run"; then
    :
  else
    worktree_status=$?
    [ "$worktree_status" -eq 1 ] && {
      mp_die "a run worktree still exists" 4
      return
    }
    mp_die "could not inspect worktrees" 3
    return
  fi

  refs=$(
    {
      git for-each-ref --format='%(refname) %(objectname)' "refs/megapowers/runs/$run/"
      git for-each-ref --format='%(refname) %(objectname)' "refs/heads/mp/$run/"
    } | LC_ALL=C sort
  )
  [ -n "$refs" ] || { mp_die "run has no refs to clean up" 3; return; }
  commands='start
'
  while IFS=' ' read -r ref oid; do
    [ -n "$ref" ] || continue
    ref_names+=("$ref")
    commands="${commands}delete $ref $oid
"
  done <<<"$refs"
  commands="${commands}prepare
commit
"
  mp_report_native_ref_locks "${ref_names[@]}" && return 4
  if ! printf '%s' "$commands" | git update-ref --stdin >/dev/null 2>&1; then
    mp_report_native_ref_locks "${ref_names[@]}" && return 4
    [ "$(mp_ref_oid_or_zero "$closed_ref")" = "$expected" ] || {
      mp_die "closed object changed before cleanup" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$generation_ref")" = "$generation_oid" ] || {
      mp_die "run generation changed before cleanup" 4
      return
    }
    mp_die "run refs changed before cleanup" 4
    return
  fi

  post_refs=$(
    {
      git for-each-ref --format='%(refname) %(objectname)' "refs/megapowers/runs/$run/"
      git for-each-ref --format='%(refname) %(objectname)' "refs/heads/mp/$run/"
    } | LC_ALL=C sort
  )
  if mp_cleanup_worktrees_clear "$run"; then
    worktree_status=0
  else
    worktree_status=$?
  fi
  if [ "$worktree_status" -eq 0 ] && [ -z "$post_refs" ]; then
    return
  fi

  restore_commands='start
'
  while IFS=' ' read -r ref oid; do
    [ -n "$ref" ] || continue
    current=$(mp_ref_oid_or_zero "$ref")
    restore_commands="${restore_commands}update $ref $oid $current
"
  done <<<"$refs"
  restore_commands="${restore_commands}prepare
commit
"
  mp_report_native_ref_locks "${ref_names[@]}" && {
    mp_die "cleanup detected a race but native locks prevent automatic restoration" 4
    return
  }
  if printf '%s' "$restore_commands" | git update-ref --stdin >/dev/null 2>&1; then
    while IFS=' ' read -r ref oid; do
      [ -n "$ref" ] || continue
      [ "$(mp_ref_oid_or_zero "$ref")" = "$oid" ] || restored=0
    done <<<"$refs"
    [ "$restored" -eq 1 ] || {
      mp_die "cleanup restoration verification failed; manual recovery is required" 3
      return
    }
    if [ "$worktree_status" -eq 1 ]; then
      mp_die "a run worktree appeared during cleanup; exact refs were restored" 4
    else
      mp_die "run state changed during cleanup; exact refs were restored" 4
    fi
    return
  fi
  mp_report_native_ref_locks "${ref_names[@]}" && return 4
  mp_die "cleanup race restoration failed; manual recovery is required" 3
}
case "${1:-}" in
  init)
    shift
    cmd_init "$@"
    ;;
  join)
    shift
    cmd_join "$@"
    ;;
  brief-put)
    shift
    cmd_brief_put "$@"
    ;;
  claim)
    shift
    cmd_claim "$@"
    ;;
  heartbeat)
    shift
    cmd_heartbeat "$@"
    ;;
  release-claim)
    shift
    cmd_release_claim "$@"
    ;;
  slot-acquire)
    shift
    cmd_slot_acquire "$@"
    ;;
  slot-release)
    shift
    cmd_slot_release "$@"
    ;;
  result-put)
    shift
    cmd_result_put "$@"
    ;;
  status)
    shift
    cmd_status "$@"
    ;;
  owner-heartbeat)
    shift
    cmd_owner_heartbeat "$@"
    ;;
  recover-claim)
    shift
    cmd_recover_claim "$@"
    ;;
  recover-slot)
    shift
    cmd_recover_slot "$@"
    ;;
  recover-owner)
    shift
    cmd_recover_owner "$@"
    ;;
  close)
    shift
    cmd_close "$@"
    ;;
  cleanup)
    shift
    cmd_cleanup "$@"
    ;;
  *)
    mp_die "usage: sdd-run init|join|brief-put|claim|heartbeat|release-claim|slot-acquire|slot-release|result-put|status|owner-heartbeat|recover-claim|recover-slot|recover-owner|close|cleanup ..." 2
    ;;
esac
