#!/usr/bin/env bash
set -euo pipefail

# Covered by scripts/tests/sdd-run.test.sh.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export MP_PROGRAM=sdd-run
# The library path is resolved from this script's runtime location.
# shellcheck disable=SC1091
source "$HERE/run-lib.sh"

mp_need_value() {
  if [ "$1" -lt 2 ]; then
    mp_die "missing value for $2" 2
    return
  fi
}

mp_positive_integer() {
  if ! [[ "$2" =~ ^[1-9][0-9]*$ ]]; then
    mp_die "$1 must be a positive integer" 2
    return
  fi
}

mp_harness() {
  case "$1" in
    codex|claude) ;;
    *) mp_die "harness must be codex or claude" 2 || return ;;
  esac
}

mp_object_id() {
  case "$(git rev-parse --show-object-format)" in
    sha1) [[ "$1" =~ ^[0-9a-f]{40}$ ]] ;;
    sha256) [[ "$1" =~ ^[0-9a-f]{64}$ ]] ;;
    *) return 1 ;;
  esac
}

mp_generation_ref() {
  mp_run_ref "$1" generation
}

mp_generation_oid() {
  local run=$1 previous=$2 operation=$3 data=$4
  jq -cn --arg run_id "$run" --arg previous "$previous" \
    --arg operation "$operation" --argjson data "$data" \
    '{version:1,run_id:$run_id,previous:$previous,operation:$operation,data:$data}' |
    git hash-object -w --stdin
}

mp_generation_moved() {
  local ref=$1 expected=$2 current
  current=$(mp_read_ref "$ref" || true)
  [ "$current" != "$expected" ]
}

mp_ref_oid_or_zero() {
  mp_read_ref "$1" || mp_zero_oid
}

mp_verifications_current() {
  local line command ref expected
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    command=${line%% *}
    line=${line#* }
    ref=${line%% *}
    expected=${line#* }
    [ "$command" = verify ] || return 1
    [ "$(mp_ref_oid_or_zero "$ref")" = "$expected" ] || return 1
  done <<<"$1"
}

mp_generation_retry() {
  local attempt=$1
  if [ "$attempt" -ge 200 ]; then
    mp_die "run generation is too contended" 4
    return
  fi
  sleep 0.02
}

mp_nodes_related() {
  case "$1/" in
    "$2/"*) return 0 ;;
  esac
  case "$2/" in
    "$1/"*) return 0 ;;
  esac
  return 1
}

mp_ownership_overlap() {
  local left=$1 right=$2
  left=$(mp_canonical_ownership_path "$left") || return
  right=$(mp_canonical_ownership_path "$right") || return
  case "$left:$right" in
    interface:*:interface:*) [ "$left" = "$right" ]; return ;;
    interface:*|*:interface:*) return 1 ;;
  esac
  [ "$left" = . ] || [ "$right" = . ] && return 0
  [ "$left" = "$right" ] && return 0
  case "$left/" in
    "$right/"*) return 0 ;;
  esac
  case "$right/" in
    "$left/"*) return 0 ;;
  esac
  return 1
}

mp_canonical_ownership_path() {
  local path=$1 segment result='' more
  case "$path" in
    interface:*) printf '%s\n' "$path"; return ;;
  esac
  while :; do
    case "$path" in
      */*) segment=${path%%/*}; path=${path#*/}; more=1 ;;
      *) segment=$path; path=''; more=0 ;;
    esac
    case "$segment" in
      ''|.) ;;
      *)
        if [ -n "$result" ]; then result="$result/$segment"
        else result=$segment
        fi
        ;;
    esac
    [ "$more" -eq 1 ] || break
  done
  [ -n "$result" ] || result=.
  printf '%s\n' "$result"
}

mp_canonical_brief_json() {
  jq -ce '
    def canonical_ownership:
      if startswith("interface:") then .
      else (split("/") | map(select(length > 0 and . != "."))) as $segments |
        if ($segments | length) == 0 then "." else ($segments | join("/")) end
      end;
    .ownership |= map(canonical_ownership)' <<<"$1"
}

mp_brief_contract() {
  local brief=$1
  jq -e \
    '(.version == 1) and
     (.run_id | type == "string") and
     (.node | type == "string") and
     ((.parent == null) or (.parent | type == "string")) and
     (.base | type == "string") and
     (.branch | type == "string") and
     (.task | type == "string" and length > 0) and
     (.acceptance | type == "array" and length > 0 and all(.[]; type == "string")) and
     (.blocked_by | type == "array" and all(.[]; type == "string")) and
     (.parallel_safety == "Safe" or .parallel_safety == "Sequential") and
     (.ownership | type == "array" and length > 0 and all(.[]; type == "string")) and
     (.may_decompose | type == "boolean") and
     ((.remaining_depth | type) == "number" and .remaining_depth >= 0 and
       (.remaining_depth | floor) == .remaining_depth) and
     ((.descendant_budget | type) == "number" and .descendant_budget >= 0 and
       (.descendant_budget | floor) == .descendant_budget) and
     ((.writer_budget | type) == "number" and .writer_budget >= 0 and
       (.writer_budget | floor) == .writer_budget) and
     ((.integration_budget | type) == "number" and .integration_budget >= 0 and
       (.integration_budget | floor) == .integration_budget)' \
    >/dev/null <<<"$brief"
}

mp_validate_ownership() {
  local brief=$1 ownership
  jq -e '
    all(.ownership[];
      length > 0 and
      (explode | all(.[]; . >= 32 and . != 127)) and
      (contains("..") | not) and
      (test("[*?\\[\\]]") | not) and
      (test("^[A-Za-z]:/") | not) and
      (test("\\\\") | not) and
      ((test("^interface:[A-Za-z0-9][A-Za-z0-9._-]*$")) or
       ((startswith("interface:") | not) and (startswith("/") | not))))' \
    >/dev/null <<<"$brief" || {
      mp_die "ownership must contain safe relative paths or interface names" 2
      return
    }
  while IFS= read -r ownership; do
    [ -n "$ownership" ] || {
      mp_die "ownership must not be empty" 2
      return
    }
  done < <(jq -r '.ownership[]' <<<"$brief")
}

mp_scope_ref() {
  local run=$1 brief=$2 parent target parent_brief
  if jq -e '.parent == null' >/dev/null <<<"$brief"; then
    target=$(mp_manifest_json "$run" | jq -r '.target_branch') || return
    printf 'refs/heads/%s\n' "$target"
    return
  fi
  parent=$(jq -r '.parent' <<<"$brief")
  parent_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$parent/brief")") || return
  target=$(jq -r '.branch' <<<"$parent_brief")
  printf 'refs/heads/%s\n' "$target"
}

MP_DEPENDENCY_VERIFICATIONS=''
MP_SCOPE_HEAD_REF=''
MP_SCOPE_HEAD_OID=''

mp_validate_dependencies() {
  local run=$1 brief=$2 dependency result result_head result_ref result_oid
  MP_DEPENDENCY_VERIFICATIONS=''
  MP_SCOPE_HEAD_REF=$(mp_scope_ref "$run" "$brief") || {
    mp_die "claim scope branch does not exist" 3
    return
  }
  MP_SCOPE_HEAD_OID=$(mp_read_ref "$MP_SCOPE_HEAD_REF") || {
    mp_die "claim scope branch does not exist" 3
    return
  }
  while IFS= read -r dependency; do
    result_ref=$(mp_run_ref "$run" "nodes/$dependency/result") || return
    result_oid=$(mp_read_ref "$result_ref") || {
      mp_die "blocked dependency is not done: $dependency" 4
      return
    }
    result=$(mp_read_json_ref "$result_oid") || {
      mp_die "blocked dependency is not done: $dependency" 4
      return
    }
    jq -e '.status == "done" and (.head | type == "string")' >/dev/null \
      <<<"$result" || {
        mp_die "blocked dependency is not done: $dependency" 4
        return
    }
    result_head=$(jq -r '.head' <<<"$result")
    git merge-base --is-ancestor "$result_head" "$MP_SCOPE_HEAD_OID" 2>/dev/null || {
      mp_die "blocked dependency is not integrated: $dependency" 4
      return
    }
    MP_DEPENDENCY_VERIFICATIONS="${MP_DEPENDENCY_VERIFICATIONS}verify $result_ref $result_oid
"
  done < <(jq -r '.blocked_by[]' <<<"$brief")
}

mp_validate_claim_peers() {
  local run=$1 node=$2 session=$3 brief=$4 ref claim other_node other_brief
  local safety other_safety ours theirs
  safety=$(jq -r '.parallel_safety' <<<"$brief")
  while IFS= read -r ref; do
    case "$ref" in
      */claim) ;;
      *) continue ;;
    esac
    claim=$(mp_read_json_ref "$ref") || {
      mp_die "active claim is malformed: $ref" 3
      return
    }
    other_node=$(jq -r '.node' <<<"$claim")
    if [ "$other_node" != "$node" ] &&
       [ "$(jq -r '.session' <<<"$claim")" = "$session" ]; then
      mp_die "session already claims another node: $other_node" 4
      return
    fi
    mp_nodes_related "$node" "$other_node" && continue
    other_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$other_node/brief")") || {
      mp_die "active claim brief is missing: $other_node" 3
      return
    }
    other_safety=$(jq -r '.parallel_safety' <<<"$other_brief")
    if [ "$safety" = Sequential ] || [ "$other_safety" = Sequential ]; then
      mp_die "sequential node cannot run beside an active peer" 4
      return
    fi
    while IFS= read -r ours; do
      while IFS= read -r theirs; do
        if mp_ownership_overlap "$ours" "$theirs"; then
          mp_die "ownership overlaps active node: $other_node" 4
          return
        fi
      done < <(jq -r '.ownership[]' <<<"$other_brief")
    done < <(jq -r '.ownership[]' <<<"$brief")
  done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" nodes)/")
}

cmd_init() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run init RUN_ID [options]" 2
    return
  fi

  local run=$1
  shift
  mp_validate_run_id "$run" || return

  local plan='' target='' session='' harness='' max_depth='' agent_budget=''
  local writers=3 integrations=1
  local seen_plan=0 seen_target=0 seen_session=0 seen_harness=0
  local seen_max_depth=0 seen_agent_budget=0 seen_writers=0 seen_integrations=0
  local allow_task_commits=0 allow_protected_target=0
  local -a roots=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plan)
        mp_need_value "$#" "$1" || return
        [ "$seen_plan" -eq 0 ] || { mp_die "duplicate --plan" 2; return; }
        plan=$2
        seen_plan=1
        shift 2
        ;;
      --root)
        mp_need_value "$#" "$1" || return
        roots+=("$2")
        shift 2
        ;;
      --target)
        mp_need_value "$#" "$1" || return
        [ "$seen_target" -eq 0 ] || { mp_die "duplicate --target" 2; return; }
        target=$2
        seen_target=1
        shift 2
        ;;
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2
        seen_session=1
        shift 2
        ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2
        seen_harness=1
        shift 2
        ;;
      --max-depth)
        mp_need_value "$#" "$1" || return
        [ "$seen_max_depth" -eq 0 ] || { mp_die "duplicate --max-depth" 2; return; }
        max_depth=$2
        seen_max_depth=1
        shift 2
        ;;
      --agent-budget)
        mp_need_value "$#" "$1" || return
        [ "$seen_agent_budget" -eq 0 ] || { mp_die "duplicate --agent-budget" 2; return; }
        agent_budget=$2
        seen_agent_budget=1
        shift 2
        ;;
      --writers)
        mp_need_value "$#" "$1" || return
        [ "$seen_writers" -eq 0 ] || { mp_die "duplicate --writers" 2; return; }
        writers=$2
        seen_writers=1
        shift 2
        ;;
      --integrations)
        mp_need_value "$#" "$1" || return
        [ "$seen_integrations" -eq 0 ] || { mp_die "duplicate --integrations" 2; return; }
        integrations=$2
        seen_integrations=1
        shift 2
        ;;
      --allow-task-commits)
        [ "$allow_task_commits" -eq 0 ] || { mp_die "duplicate --allow-task-commits" 2; return; }
        allow_task_commits=1
        shift
        ;;
      --allow-protected-target)
        [ "$allow_protected_target" -eq 0 ] || { mp_die "duplicate --allow-protected-target" 2; return; }
        allow_protected_target=1
        shift
        ;;
      *)
        mp_die "unknown init option: $1" 2
        return
        ;;
    esac
  done

  [ "$seen_plan" -eq 1 ] || { mp_die "missing --plan" 2; return; }
  [ "${#roots[@]}" -gt 0 ] || { mp_die "at least one --root is required" 2; return; }
  [ "$seen_target" -eq 1 ] || { mp_die "missing --target" 2; return; }
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  [ "$seen_max_depth" -eq 1 ] || { mp_die "missing --max-depth" 2; return; }
  [ "$seen_agent_budget" -eq 1 ] || { mp_die "missing --agent-budget" 2; return; }
  [ "$allow_task_commits" -eq 1 ] || { mp_die "--allow-task-commits is required" 2; return; }

  [ -f "$plan" ] || { mp_die "no such plan file: $plan" 2; return; }
  mp_positive_integer "max-depth" "$max_depth" || return
  mp_positive_integer "agent-budget" "$agent_budget" || return
  mp_positive_integer "writers" "$writers" || return
  mp_positive_integer "integrations" "$integrations" || return
  [ "$max_depth" -le 5 ] || { mp_die "max-depth must be no greater than 5" 2; return; }
  [ "$agent_budget" -ge "${#roots[@]}" ] || { mp_die "agent-budget must cover every root" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local root seen_root
  local -a seen_roots=()
  for root in "${roots[@]}"; do
    mp_validate_node_path "$root" || return
    for seen_root in "${seen_roots[@]}"; do
      if [ "$seen_root" = "$root" ]; then
        mp_die "duplicate root: $root" 2
        return
      fi
    done
    seen_roots+=("$root")
  done

  git check-ref-format --branch "$target" >/dev/null 2>&1 || {
    mp_die "invalid target branch: $target" 2
    return
  }
  git show-ref --verify --quiet "refs/heads/$target" || {
    mp_die "target branch does not exist: $target" 2
    return
  }
  local current_branch
  current_branch=$(git symbolic-ref --quiet --short HEAD) || {
    mp_die "current checkout is detached" 2
    return
  }
  [ "$current_branch" = "$target" ] || {
    mp_die "current checkout is not on target branch: $target" 2
    return
  }
  [ -z "$(git status --porcelain)" ] || {
    mp_die "current checkout must be clean" 2
    return
  }
  case "$target" in
    main|master|release)
      [ "$allow_protected_target" -eq 1 ] || {
        mp_die "protected target requires --allow-protected-target: $target" 2
        return
      }
      ;;
  esac

  local roots_json created_at manifest_oid plan_oid owner_oid generation_oid
  local manifest_ref plan_ref owner_ref generation_ref
  roots_json=$(printf '%s\n' "${roots[@]}" | jq -Rsc 'split("\n") | map(select(length > 0))')
  created_at=$(mp_now)
  manifest_oid=$(
    jq -cn \
      --arg run_id "$run" --arg target_branch "$target" \
      --arg target_base "$(git rev-parse HEAD)" --arg created_at "$created_at" \
      --argjson roots "$roots_json" --argjson max_depth "$max_depth" \
      --argjson agent_budget "$agent_budget" --argjson writer_limit "$writers" \
      --argjson integration_limit "$integrations" \
      '{version:1,run_id:$run_id,target_branch:$target_branch,target_base:$target_base,
        harnesses:["codex","claude"],roots:$roots,max_depth:$max_depth,
        agent_budget:$agent_budget,writer_limit:$writer_limit,
        integration_limit:$integration_limit,task_commits:true,created_at:$created_at}' |
      git hash-object -w --stdin
  )
  plan_oid=$(git hash-object -w "$plan")
  owner_oid=$(
    jq -cn --arg session "$session" --arg harness "$harness" \
      --arg at "$created_at" '{session:$session,harness:$harness,claimed_at:$at,last_activity:$at}' |
      git hash-object -w --stdin
  )
  generation_oid=$(
    jq -cn --arg run_id "$run" --arg manifest "$manifest_oid" --arg plan "$plan_oid" \
      --arg owner "$owner_oid" \
      '{version:1,run_id:$run_id,previous:null,operation:"init",
        data:{manifest:$manifest,plan:$plan,owner:$owner}}' |
      git hash-object -w --stdin
  )
  manifest_ref=$(mp_run_ref "$run" manifest) || return
  plan_ref=$(mp_run_ref "$run" plan) || return
  owner_ref=$(mp_run_ref "$run" owner) || return
  generation_ref=$(mp_generation_ref "$run") || return
  if ! git update-ref --stdin <<EOF
start
create $manifest_ref $manifest_oid
create $plan_ref $plan_oid
create $owner_ref $owner_oid
create $generation_ref $generation_oid
prepare
commit
EOF
  then
    mp_die "run already exists or creation race was lost" 4
  fi
}

cmd_join() {
  if [ "$#" -lt 1 ]; then
    mp_die "usage: sdd-run join RUN_ID --plan FILE --target BRANCH --harness codex|claude" 2
    return
  fi

  local run=$1
  shift
  mp_validate_run_id "$run" || return

  local plan='' target='' harness=''
  local seen_plan=0 seen_target=0 seen_harness=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plan)
        mp_need_value "$#" "$1" || return
        [ "$seen_plan" -eq 0 ] || { mp_die "duplicate --plan" 2; return; }
        plan=$2
        seen_plan=1
        shift 2
        ;;
      --target)
        mp_need_value "$#" "$1" || return
        [ "$seen_target" -eq 0 ] || { mp_die "duplicate --target" 2; return; }
        target=$2
        seen_target=1
        shift 2
        ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2
        seen_harness=1
        shift 2
        ;;
      *)
        mp_die "unknown join option: $1" 2
        return
        ;;
    esac
  done

  [ "$seen_plan" -eq 1 ] || { mp_die "missing --plan" 2; return; }
  [ "$seen_target" -eq 1 ] || { mp_die "missing --target" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  [ -f "$plan" ] || { mp_die "no such plan file: $plan" 2; return; }
  git check-ref-format --branch "$target" >/dev/null 2>&1 || {
    mp_die "invalid target branch: $target" 2
    return
  }
  mp_harness "$harness" || return

  local plan_ref expected_plan supplied_plan manifest
  plan_ref=$(mp_run_ref "$run" plan) || return
  expected_plan=$(mp_read_ref "$plan_ref") || {
    mp_die "run does not exist: $run" 3
    return
  }
  supplied_plan=$(git hash-object "$plan")
  [ "$supplied_plan" = "$expected_plan" ] || {
    mp_die "plan does not match immutable run state" 3
    return
  }
  manifest=$(mp_manifest_json "$run") || {
    mp_die "run manifest is missing or malformed" 3
    return
  }
  [ "$(jq -r '.target_branch' <<<"$manifest")" = "$target" ] || {
    mp_die "target branch does not match immutable run state" 3
    return
  }
  jq -e --arg harness "$harness" '.harnesses | index($harness) != null' \
    <<<"$manifest" >/dev/null || {
      mp_die "harness does not match immutable run state" 3
      return
    }
}

cmd_brief_put() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run brief-put RUN_ID NODE BRIEF.json --session ID" 2
    return
  fi

  local run=$1 node=$2 brief_file=$3 session='' seen_session=0
  shift 3
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  [ -f "$brief_file" ] || { mp_die "no such brief file: $brief_file" 2; return; }
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2
        seen_session=1
        shift 2
        ;;
      *) mp_die "unknown brief-put option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  mp_validate_session_id "$session" || return

  local snapshot_oid brief manifest document_run document_node expected_branch base
  local remaining descendant writers integrations may_decompose
  snapshot_oid=$(git hash-object -w -- "$brief_file") || {
    mp_die "could not snapshot brief" 2
    return
  }
  brief=$(git cat-file blob "$snapshot_oid") || {
    mp_die "could not read brief snapshot" 2
    return
  }
  manifest=$(mp_manifest_json "$run") || {
    mp_die "run does not exist: $run" 3
    return
  }
  mp_brief_contract "$brief" || {
    mp_die "brief does not match the version 1 contract" 2
    return
  }
  document_run=$(jq -r '.run_id' <<<"$brief")
  document_node=$(jq -r '.node' <<<"$brief")
  [ "$document_run" = "$run" ] || { mp_die "brief run_id does not match command" 2; return; }
  [ "$document_node" = "$node" ] || { mp_die "brief node does not match command" 2; return; }
  expected_branch="mp/$run/nodes/$node/head"
  [ "$(jq -r '.branch' <<<"$brief")" = "$expected_branch" ] || {
    mp_die "brief branch must be $expected_branch" 2
    return
  }
  base=$(jq -r '.base' <<<"$brief")
  [ "$(git cat-file -t "$base" 2>/dev/null || true)" = commit ] || {
    mp_die "brief base must name a commit object" 2
    return
  }
  jq -e 'all(.blocked_by[]; (explode | all(.[]; . >= 32 and . != 127)))' \
    >/dev/null <<<"$brief" || { mp_die "blocked_by contains control characters" 2; return; }
  local dependency
  while IFS= read -r dependency; do
    mp_validate_node_path "$dependency" || return
  done < <(jq -r '.blocked_by[]' <<<"$brief")
  mp_validate_ownership "$brief" || return

  remaining=$(jq -r '.remaining_depth' <<<"$brief")
  descendant=$(jq -r '.descendant_budget' <<<"$brief")
  writers=$(jq -r '.writer_budget' <<<"$brief")
  integrations=$(jq -r '.integration_budget' <<<"$brief")
  may_decompose=$(jq -r '.may_decompose' <<<"$brief")
  if [ "$may_decompose" = true ]; then
    [ "$remaining" -gt 0 ] && [ "$descendant" -gt 0 ] || {
      mp_die "decomposable briefs require positive depth and descendant budget" 2
      return
    }
  else
    [ "$remaining" -eq 0 ] && [ "$descendant" -eq 0 ] || {
      mp_die "non-decomposable briefs require zero depth and descendant budget" 2
      return
    }
  fi

  local brief_json brief_oid brief_ref generation_ref generation_oid new_generation
  local generation_data attempt=0 parent current_head owner owner_ref total root root_brief parent_brief
  local parent_remaining parent_descendant parent_writers parent_integrations candidate_ref
  local authorization_ref authorization_oid head_ref
  brief_json=$(mp_canonical_brief_json "$brief") || {
    mp_die "could not canonicalize brief ownership" 2
    return
  }
  brief_oid=$(printf '%s\n' "$brief_json" | git hash-object -w --stdin) || {
    mp_die "could not hash brief" 2
    return
  }
  brief_ref=$(mp_run_ref "$run" "nodes/$node/brief") || return
  generation_ref=$(mp_generation_ref "$run") || return

  [ "$writers" -le "$(jq -r '.writer_limit' <<<"$manifest")" ] || {
    mp_die "writer budget exceeds the manifest limit" 2
    return
  }
  [ "$integrations" -le "$(jq -r '.integration_limit' <<<"$manifest")" ] || {
    mp_die "integration budget exceeds the manifest limit" 2
    return
  }

  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || {
      mp_die "run generation is missing" 3
      return
    }
    total=0
    if jq -e '.parent == null' >/dev/null <<<"$brief"; then
      jq -e --arg node "$node" '.roots | index($node) != null' >/dev/null \
        <<<"$manifest" || { mp_die "root node is not declared in the manifest" 2; return; }
      owner_ref=$(mp_run_ref "$run" owner) || return
      authorization_ref=$owner_ref
      authorization_oid=$(mp_read_ref "$authorization_ref") || { mp_die "run owner is missing" 3; return; }
      owner=$(mp_read_json_ref "$authorization_oid") || { mp_die "run owner is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$owner")" = "$session" ] || {
        mp_die "root brief requires the owner session" 4
        return
      }
      head_ref="refs/heads/$(jq -r '.target_branch' <<<"$manifest")"
      current_head=$(mp_read_ref "$head_ref") || { mp_die "target branch does not exist" 3; return; }
      [ "$base" = "$current_head" ] || { mp_die "root brief base is not the current target head" 4; return; }
      [ "$remaining" -le "$(jq -r '.max_depth' <<<"$manifest")" ] || {
        mp_die "root remaining depth exceeds the manifest limit" 2
        return
      }
      while IFS= read -r root; do
        [ "$root" = "$node" ] && continue
        if root_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$root/brief")"); then
          total=$((total + 1 + $(jq -r '.descendant_budget' <<<"$root_brief")))
        fi
      done < <(jq -r '.roots[]' <<<"$manifest")
      total=$((total + 1 + descendant))
      [ "$total" -le "$(jq -r '.agent_budget' <<<"$manifest")" ] || {
        mp_die "root briefs exceed the run agent budget" 4
        return
      }
    else
      parent=$(jq -r '.parent' <<<"$brief")
      case "$node" in */*) ;; *) mp_die "child node must be below its parent" 2; return ;; esac
      [ "${node%/*}" = "$parent" ] || {
        mp_die "child node must be exactly one segment below its parent" 2
        return
      }
      mp_validate_node_path "$parent" || return
      parent_brief=$(mp_read_json_ref "$(mp_run_ref "$run" "nodes/$parent/brief")") || {
        mp_die "parent brief does not exist" 3
        return
      }
      authorization_ref=$(mp_run_ref "$run" "nodes/$parent/claim") || return
      authorization_oid=$(mp_read_ref "$authorization_ref") || {
        mp_die "parent node is not actively claimed" 4
        return
      }
      owner=$(mp_read_json_ref "$authorization_oid") || { mp_die "parent claim is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$owner")" = "$session" ] || {
        mp_die "child brief requires the parent claimant session" 4
        return
      }
      head_ref="refs/heads/$(jq -r '.branch' <<<"$parent_brief")"
      current_head=$(mp_read_ref "$head_ref") || { mp_die "parent branch does not exist" 3; return; }
      [ "$base" = "$current_head" ] || { mp_die "child brief base is not the current parent head" 4; return; }
      parent_remaining=$(jq -r '.remaining_depth' <<<"$parent_brief")
      parent_descendant=$(jq -r '.descendant_budget' <<<"$parent_brief")
      parent_writers=$(jq -r '.writer_budget' <<<"$parent_brief")
      parent_integrations=$(jq -r '.integration_budget' <<<"$parent_brief")
      [ "$remaining" -lt "$parent_remaining" ] || {
        mp_die "child remaining depth must be smaller than its parent" 2
        return
      }
      while IFS= read -r candidate_ref; do
        case "$candidate_ref" in */brief) ;; *) continue ;; esac
        [ "$candidate_ref" = "$brief_ref" ] && continue
        root_brief=$(mp_read_json_ref "$candidate_ref") || continue
        [ "$(jq -r '.parent // ""' <<<"$root_brief")" = "$parent" ] || continue
        total=$((total + 1 + $(jq -r '.descendant_budget' <<<"$root_brief")))
      done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" "nodes/$parent")/")
      total=$((total + 1 + descendant))
      [ "$total" -le "$parent_descendant" ] || {
        mp_die "sibling briefs exceed the parent descendant budget" 4
        return
      }
      [ "$writers" -le "$parent_writers" ] || { mp_die "child writer budget exceeds its parent" 2; return; }
      [ "$integrations" -le "$parent_integrations" ] || { mp_die "child integration budget exceeds its parent" 2; return; }
    fi

    generation_data=$(jq -cn --arg node "$node" --arg snapshot "$snapshot_oid" \
      --arg brief "$brief_oid" --arg authorization "$authorization_oid" --arg head "$current_head" \
      '{node:$node,snapshot:$snapshot,brief:$brief,authorization:$authorization,head:$head}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" brief-put "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $authorization_ref $authorization_oid
verify $head_ref $current_head
create $brief_ref $brief_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    if ! mp_generation_moved "$generation_ref" "$generation_oid"; then
      [ "$(mp_read_ref "$authorization_ref" || true)" = "$authorization_oid" ] || {
        mp_die "brief authorization changed" 4
        return
      }
      [ "$(mp_read_ref "$head_ref" || true)" = "$current_head" ] || {
        mp_die "brief scope branch changed" 4
        return
      }
      mp_read_ref "$brief_ref" >/dev/null && {
        mp_die "node brief already exists" 4
        return
      }
    fi
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_claim() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run claim RUN_ID NODE --session ID --harness codex|claude" 2
    return
  fi
  local run=$1 node=$2 session='' harness='' seen_session=0 seen_harness=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2; seen_harness=1; shift 2 ;;
      *) mp_die "unknown claim option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local brief_ref brief_oid brief result_ref result_oid result claim_ref generation_ref
  local generation_oid new_generation generation_data claim_oid at attempt=0
  brief_ref=$(mp_run_ref "$run" "nodes/$node/brief") || return
  result_ref=$(mp_run_ref "$run" "nodes/$node/result") || return
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    brief_oid=$(mp_read_ref "$brief_ref") || { mp_die "node brief does not exist" 3; return; }
    brief=$(mp_read_json_ref "$brief_oid") || { mp_die "node brief is malformed" 3; return; }
    result_oid=$(mp_ref_oid_or_zero "$result_ref")
    if [ "$result_oid" != "$(mp_zero_oid)" ]; then
      result=$(mp_read_json_ref "$result_oid") || { mp_die "node result is malformed" 3; return; }
      if jq -e '.status == "done"' >/dev/null <<<"$result"; then
        mp_die "node already has a terminal done result" 4
        return
      fi
    fi
    mp_validate_dependencies "$run" "$brief" || return
    mp_validate_claim_peers "$run" "$node" "$session" "$brief" || return
    at=$(mp_now)
    generation_data=$(jq -cn --arg node "$node" --arg session "$session" \
      --arg harness "$harness" --arg brief "$brief_oid" --arg result "$result_oid" \
      --arg scope_head "$MP_SCOPE_HEAD_OID" \
      '{node:$node,session:$session,harness:$harness,brief:$brief,
        result:$result,scope_head:$scope_head}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" claim "$generation_data") || return
    claim_oid=$(
      printf '%s\n' "$brief" |
        jq -c --arg session "$session" --arg harness "$harness" --arg at "$at" \
          --arg generation "$new_generation" \
          '{session:$session,harness:$harness,node:.node,branch:.branch,base:.base,
            claimed_at:$at,last_activity:$at,generation:$generation}' |
        git hash-object -w --stdin
    )
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $brief_ref $brief_oid
verify $result_ref $result_oid
verify $MP_SCOPE_HEAD_REF $MP_SCOPE_HEAD_OID
${MP_DEPENDENCY_VERIFICATIONS}create $claim_ref $claim_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s %s\n' "$claim_oid" "$(jq -r '.branch' <<<"$brief")"
      return
    fi
    [ "$(mp_ref_oid_or_zero "$brief_ref")" = "$brief_oid" ] || {
      mp_die "node brief changed before claim" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$result_ref")" = "$result_oid" ] || {
      mp_die "node result changed before claim" 4
      return
    }
    [ "$(mp_ref_oid_or_zero "$MP_SCOPE_HEAD_REF")" = "$MP_SCOPE_HEAD_OID" ] || {
      mp_die "claim scope branch changed" 4
      return
    }
    mp_verifications_current "$MP_DEPENDENCY_VERIFICATIONS" || {
      mp_die "claim dependency changed" 4
      return
    }
    mp_read_ref "$claim_ref" >/dev/null && { mp_die "node already claimed" 4; return; }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_heartbeat() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run heartbeat RUN_ID NODE --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 node=$2 session='' expected='' seen_session=0 seen_expected=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown heartbeat option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }

  local claim at new_oid claim_ref generation_ref generation_oid new_generation
  local generation_data attempt=0
  claim=$(mp_read_json_ref "$expected") || { mp_die "expected claim object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$claim")" = "$session" ] || {
    mp_die "claim belongs to another session" 4
    return
  }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    at=$(mp_now)
    generation_data=$(jq -cn --arg node "$node" --arg session "$session" \
      --arg expected "$expected" --arg at "$at" \
      '{node:$node,session:$session,expected:$expected,last_activity:$at}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" heartbeat "$generation_data") || return
    new_oid=$(printf '%s\n' "$claim" |
      jq -c --arg at "$at" --arg generation "$new_generation" \
        '.last_activity=$at | .generation=$generation' |
      git hash-object -w --stdin)
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
update $claim_ref $new_oid $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s\n' "$new_oid"
      return
    fi
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$expected" ] || {
      mp_die "claim changed before heartbeat" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_release_claim() {
  if [ "$#" -lt 2 ]; then
    mp_die "usage: sdd-run release-claim RUN_ID NODE --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 node=$2 session='' expected='' seen_session=0 seen_expected=0
  shift 2
  mp_validate_run_id "$run" || return
  mp_validate_node_path "$node" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown release-claim option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local claim claim_ref generation_ref generation_oid new_generation generation_data attempt=0
  claim=$(mp_read_json_ref "$expected") || { mp_die "expected claim object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$claim")" = "$session" ] || {
    mp_die "claim belongs to another session" 4
    return
  }
  claim_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
  generation_ref=$(mp_generation_ref "$run") || return
  generation_data=$(jq -cn --arg node "$node" --arg session "$session" --arg expected "$expected" \
    '{node:$node,session:$session,expected:$expected}')
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    new_generation=$(mp_generation_oid "$run" "$generation_oid" release-claim "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
delete $claim_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    [ "$(mp_ref_oid_or_zero "$claim_ref")" = "$expected" ] || {
      mp_die "claim changed before release" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_slot_acquire() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run slot-acquire RUN_ID writer|integration NODE|@target --session ID --harness codex|claude [--expected-owner OBJECT_ID]" 2
    return
  fi
  local run=$1 kind=$2 node=$3 session='' harness='' expected_owner=''
  local seen_session=0 seen_harness=0 seen_expected_owner=0
  shift 3
  mp_validate_run_id "$run" || return
  case "$kind" in writer|integration) ;; *) mp_die "slot kind must be writer or integration" 2; return ;; esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --harness)
        mp_need_value "$#" "$1" || return
        [ "$seen_harness" -eq 0 ] || { mp_die "duplicate --harness" 2; return; }
        harness=$2; seen_harness=1; shift 2 ;;
      --expected-owner)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected_owner" -eq 0 ] || { mp_die "duplicate --expected-owner" 2; return; }
        expected_owner=$2; seen_expected_owner=1; shift 2 ;;
      *) mp_die "unknown slot-acquire option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_harness" -eq 1 ] || { mp_die "missing --harness" 2; return; }
  mp_validate_session_id "$session" || return
  mp_harness "$harness" || return

  local manifest limit scope owner_oid='' identity claim ref slot_json slot_oid at slot
  local identity_ref identity_oid slot_ref generation_ref generation_oid new_generation
  local generation_data attempt=0 existing
  manifest=$(mp_manifest_json "$run") || { mp_die "run does not exist: $run" 3; return; }
  if [ "$kind" = writer ]; then limit=$(jq -r '.writer_limit' <<<"$manifest")
  else limit=$(jq -r '.integration_limit' <<<"$manifest")
  fi
  if [ "$node" = @target ]; then
    [ "$kind" = integration ] || { mp_die "writer @target is not allowed" 2; return; }
    [ "$seen_expected_owner" -eq 1 ] || { mp_die "@target requires --expected-owner" 2; return; }
    mp_object_id "$expected_owner" || { mp_die "expected owner must be an object ID" 2; return; }
    identity_ref=$(mp_run_ref "$run" owner) || return
    scope=target
  else
    [ "$seen_expected_owner" -eq 0 ] || { mp_die "--expected-owner is only valid for @target" 2; return; }
    mp_validate_node_path "$node" || return
    mp_read_json_ref "$(mp_run_ref "$run" "nodes/$node/brief")" >/dev/null || {
      mp_die "node brief does not exist" 3
      return
    }
    identity_ref=$(mp_run_ref "$run" "nodes/$node/claim") || return
    scope=node
  fi
  generation_ref=$(mp_generation_ref "$run") || return

  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    identity_oid=$(mp_read_ref "$identity_ref") || {
      if [ "$scope" = target ]; then mp_die "run owner is missing" 3
      else mp_die "node is not actively claimed" 4
      fi
      return
    }
    if [ "$scope" = target ]; then
      owner_oid=$identity_oid
      [ "$owner_oid" = "$expected_owner" ] || { mp_die "run owner changed" 4; return; }
      identity=$(mp_read_json_ref "$identity_oid") || { mp_die "owner object is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$identity")" = "$session" ] &&
        [ "$(jq -r '.harness' <<<"$identity")" = "$harness" ] || {
          mp_die "integration slot requires the elected owner" 4
          return
        }
    else
      claim=$(mp_read_json_ref "$identity_oid") || { mp_die "active node claim is malformed" 3; return; }
      [ "$(jq -r '.session' <<<"$claim")" = "$session" ] &&
        [ "$(jq -r '.harness' <<<"$claim")" = "$harness" ] || {
          mp_die "slot requires the active node claimant" 4
          return
        }
    fi

    while IFS= read -r ref; do
      existing=$(mp_read_json_ref "$ref") || { mp_die "active slot is malformed: $ref" 3; return; }
      if [ "$scope" = node ] && [ "$(jq -r '.scope' <<<"$existing")" = node ] &&
         [ "$(jq -r '.node' <<<"$existing")" = "$node" ]; then
        mp_die "node already holds a $kind slot" 4
        return
      fi
      if [ "$scope" = target ] && [ "$(jq -r '.scope' <<<"$existing")" = target ]; then
        mp_die "target already holds an integration slot" 4
        return
      fi
    done < <(git for-each-ref --format='%(refname)' "$(mp_run_ref "$run" "slots/$kind")/")

    slot=1
    while [ "$slot" -le "$limit" ] &&
          mp_read_ref "$(mp_run_ref "$run" "slots/$kind/$slot")" >/dev/null; do
      slot=$((slot + 1))
    done
    [ "$slot" -le "$limit" ] || { mp_die "no $kind slot available" 4; return; }
    at=$(mp_now)
    generation_data=$(jq -cn --arg kind "$kind" --arg scope "$scope" --arg node "$node" \
      --arg session "$session" --arg harness "$harness" --arg identity "$identity_oid" \
      --argjson slot "$slot" \
      '{kind:$kind,scope:$scope,node:$node,session:$session,harness:$harness,
        identity:$identity,slot:$slot}')
    new_generation=$(mp_generation_oid "$run" "$generation_oid" slot-acquire "$generation_data") || return
    if [ "$scope" = node ]; then
      slot_json=$(jq -cn --arg session "$session" --arg harness "$harness" \
        --arg node "$node" --arg kind "$kind" --argjson slot "$slot" --arg at "$at" \
        --arg generation "$new_generation" \
        '{session:$session,harness:$harness,scope:"node",node:$node,kind:$kind,
          slot:$slot,claimed_at:$at,generation:$generation}')
    else
      slot_json=$(jq -cn --arg session "$session" --arg harness "$harness" \
        --arg kind "$kind" --argjson slot "$slot" --arg at "$at" --arg owner_oid "$owner_oid" \
        --arg generation "$new_generation" \
        '{session:$session,harness:$harness,scope:"target",node:null,kind:$kind,
          slot:$slot,claimed_at:$at,owner_oid:$owner_oid,generation:$generation}')
    fi
    slot_oid=$(printf '%s\n' "$slot_json" | git hash-object -w --stdin)
    slot_ref=$(mp_run_ref "$run" "slots/$kind/$slot") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
verify $identity_ref $identity_oid
create $slot_ref $slot_oid
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      printf '%s %s\n' "$slot" "$slot_oid"
      return
    fi
    [ "$(mp_ref_oid_or_zero "$identity_ref")" = "$identity_oid" ] || {
      mp_die "slot authorization changed before creation" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

cmd_slot_release() {
  if [ "$#" -lt 3 ]; then
    mp_die "usage: sdd-run slot-release RUN_ID writer|integration SLOT --session ID --expected OBJECT_ID" 2
    return
  fi
  local run=$1 kind=$2 slot=$3 session='' expected='' seen_session=0 seen_expected=0
  shift 3
  mp_validate_run_id "$run" || return
  case "$kind" in writer|integration) ;; *) mp_die "slot kind must be writer or integration" 2; return ;; esac
  mp_positive_integer "slot" "$slot" || return
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --session)
        mp_need_value "$#" "$1" || return
        [ "$seen_session" -eq 0 ] || { mp_die "duplicate --session" 2; return; }
        session=$2; seen_session=1; shift 2 ;;
      --expected)
        mp_need_value "$#" "$1" || return
        [ "$seen_expected" -eq 0 ] || { mp_die "duplicate --expected" 2; return; }
        expected=$2; seen_expected=1; shift 2 ;;
      *) mp_die "unknown slot-release option: $1" 2; return ;;
    esac
  done
  [ "$seen_session" -eq 1 ] || { mp_die "missing --session" 2; return; }
  [ "$seen_expected" -eq 1 ] || { mp_die "missing --expected" 2; return; }
  mp_validate_session_id "$session" || return
  mp_object_id "$expected" || { mp_die "expected must be an object ID" 2; return; }
  local manifest limit slot_json slot_ref generation_ref generation_oid new_generation
  local generation_data attempt=0
  manifest=$(mp_manifest_json "$run") || { mp_die "run does not exist: $run" 3; return; }
  if [ "$kind" = writer ]; then limit=$(jq -r '.writer_limit' <<<"$manifest")
  else limit=$(jq -r '.integration_limit' <<<"$manifest")
  fi
  [ "$slot" -le "$limit" ] || { mp_die "slot number exceeds the manifest limit" 2; return; }
  slot_json=$(mp_read_json_ref "$expected") || { mp_die "expected slot object is missing" 3; return; }
  [ "$(jq -r '.session' <<<"$slot_json")" = "$session" ] &&
    [ "$(jq -r '.kind' <<<"$slot_json")" = "$kind" ] &&
    [ "$(jq -r '.slot' <<<"$slot_json")" = "$slot" ] || {
      mp_die "slot object does not match the release request" 4
      return
    }
  slot_ref=$(mp_run_ref "$run" "slots/$kind/$slot") || return
  generation_ref=$(mp_generation_ref "$run") || return
  generation_data=$(jq -cn --arg kind "$kind" --argjson slot "$slot" \
    --arg session "$session" --arg expected "$expected" \
    '{kind:$kind,slot:$slot,session:$session,expected:$expected}')
  while :; do
    generation_oid=$(mp_read_ref "$generation_ref") || { mp_die "run generation is missing" 3; return; }
    new_generation=$(mp_generation_oid "$run" "$generation_oid" slot-release "$generation_data") || return
    if git update-ref --stdin >/dev/null 2>&1 <<EOF
start
delete $slot_ref $expected
update $generation_ref $new_generation $generation_oid
prepare
commit
EOF
    then
      return
    fi
    [ "$(mp_ref_oid_or_zero "$slot_ref")" = "$expected" ] || {
      mp_die "slot changed before release" 4
      return
    }
    attempt=$((attempt + 1))
    mp_generation_retry "$attempt" || return
  done
}

case "${1:-}" in
  init)
    shift
    cmd_init "$@"
    ;;
  join)
    shift
    cmd_join "$@"
    ;;
  brief-put)
    shift
    cmd_brief_put "$@"
    ;;
  claim)
    shift
    cmd_claim "$@"
    ;;
  heartbeat)
    shift
    cmd_heartbeat "$@"
    ;;
  release-claim)
    shift
    cmd_release_claim "$@"
    ;;
  slot-acquire)
    shift
    cmd_slot_acquire "$@"
    ;;
  slot-release)
    shift
    cmd_slot_release "$@"
    ;;
  *)
    mp_die "usage: sdd-run init|join|brief-put|claim|heartbeat|release-claim|slot-acquire|slot-release ..." 2
    ;;
esac
