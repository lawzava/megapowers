#!/usr/bin/env bash
# SessionStart hook for the megapowers plugin (Claude Code only).

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-megapowers and inject a trimmed, Claude-Code-only variant of it. This hook
# runs on every startup, /clear, and compaction, so the payload is always-in-context;
# keep it a lean nudge, not the whole skill. Strip, via awk range filters:
#   - the YAML frontmatter (its name + description already appear in the skills listing);
#   - the "## Platform Adaptation" section (points OTHER harnesses at their reference
#     files; inert on Claude Code, the only harness that runs this hook);
#   - the trailing "Origin:" license footer (an attribution notice that must live in the
#     file so it travels the bare-SKILL.md skills CLI channel, but does not belong in the
#     always-in-context nudge).
# "## Communication" carries the required communication-register rules and stays in the
# payload; SKILL.md keeps that section condensed so the nudge stays lean without dropping
# a rule. The file on disk stays complete and portable for full reads / other harnesses.
skill_file="${PLUGIN_ROOT}/skills/using-megapowers/SKILL.md"
if [ -r "${skill_file}" ]; then
  using_megapowers_content=$(awk '
    NR==1 && /^---/ { fm=1; next }
    fm && /^---/    { fm=0; next }
    fm              { next }
    /^## /          { drop = ($0 ~ /^## (Platform Adaptation)$/) }
    drop            { next }
    /^Origin: Derived from Superpowers / { next }
                    { print }
  ' "${skill_file}")
else
  using_megapowers_content="Error reading using-megapowers skill"
fi

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

preface="megapowers workflow skills are available (planning, testing, debugging, review). Before acting on a request (including clarifying questions or exploring code), check whether a skill applies and, if so, follow it."

# Model catalog block: rendered live from models.toml layers so every session
# knows what models exist and what each is for. Fail-open: absent or malformed
# catalog leaves the payload exactly as before.
catalog_block="$("${SCRIPT_DIR}/render-model-catalog" 2>/dev/null || true)"

using_megapowers_escaped=$(escape_for_json "$using_megapowers_content")
preface_escaped=$(escape_for_json "$preface")
session_context="${preface_escaped}\n\n${using_megapowers_escaped}"
if [ -n "${catalog_block}" ]; then
  catalog_escaped=$(escape_for_json "$catalog_block")
  session_context="${session_context}\n\n${catalog_escaped}"
fi

# Output context injection as JSON for Claude Code.
# Claude Code reads hookSpecificOutput.additionalContext (nested).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
