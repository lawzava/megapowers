#!/usr/bin/env bash
# Cross-harness SessionStart dispatcher. Codex sets PLUGIN_ROOT; Claude Code
# does not. Fail open when the selected sibling is unavailable or errors.
set -u

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
input="$(cat 2>/dev/null || true)"
if [ -n "${PLUGIN_ROOT:-}" ]; then
  target="$here/codex-session-catalog.sh"
else
  target="$here/session-start"
fi
[ -x "$target" ] || exit 0
printf '%s' "$input" | "$target" 2>/dev/null || true
exit 0
