#!/usr/bin/env bash
# delegate-resolve <role> — resolve a role to its provider + invocation details by
# reading delegates.toml. Makes routing EXECUTED rather than eyeballed: any harness
# can run this (or read its KEY=VALUE output) to learn where a role goes and how to
# reach it. Portable: bash + awk, no external deps.
# Tested by tests/delegate-resolve.test.sh (run via scripts/validate.sh).
#
# Config layering: DELEGATES_TOML (env) and --config are exclusive single-file
# modes; when either is set, only that file is read. Otherwise up to three layers
# merge per key, highest priority first:
#   1. project  .megapowers/delegates.toml            (relative to the caller's cwd)
#   2. user     ${XDG_CONFIG_HOME:-~/.config}/megapowers/delegates.toml
#   3. shipped  the delegates.toml in this skill's directory (always present)
# The first layer that defines a key wins; arrays replace whole, never merge.
# `--where` prints the active layers in priority order.
#
# Catalog stack: the model catalog (lead, tiers, providers, floor) lives in
# models.toml, layered the same way: MODELS_TOML (env) and --models are exclusive
# single-file modes; otherwise project .megapowers/models.toml, then user
# ${XDG_CONFIG_HOME:-~/.config}/megapowers/models.toml, then the copy shipped at
# this plugin's root. Catalog data resolves DELEGATES stack first (legacy
# compatibility: provider sections in delegates.toml layers win), then the
# catalog stack. The catalog stack may be empty.
#
# Reads a restricted TOML subset matching delegates.toml: [section] and
# [section.name] headers (internal whitespace tolerated), one `key = value` per
# line, values either bare or single/double quoted, `#` comments outside quotes,
# plus single-line arrays of quoted strings. Multi-line strings and inline tables
# are not parsed.
#
# Resolution walks the role's fallback chain (or its single [roles] provider when it
# has none), skipping any candidate that is --excluded, disabled, or whose CLI is not
# installed (checked with `command -v <binary>`: a route to an absent CLI is a
# fabricated primitive). The first usable candidate wins.
#
# Usage:
#   delegate-resolve <role> [--config <file>] [--models <file>] [--exclude <vendor|provider>]... [--list]
#   delegate-resolve --preset <name> [--config <file>]
#   delegate-resolve --list-presets [--config <file>]
#   delegate-resolve --where [--config <file>]
#   delegate-resolve --lead | --exclude-lead | --check [--config <file>]
# Exit:  0 resolved · 2 usage/config/parse error · 3 unknown role OR no available
#        route (every candidate excluded/disabled/absent) · 4 provider disabled (a
#        single-route role whose only provider is switched off in config)
#        --check: 0 clean, 1 schema findings.
set -uo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
shipped="$here/../delegates.toml"   # scripts/../delegates.toml

usage() {
  echo "usage: delegate-resolve <role> [--config <file>] [--models <file>] [--exclude <vendor|provider>]... [--list]" >&2
  echo "       delegate-resolve --preset <name> [--config <file>] | --list-presets | --where | --lead | --check" >&2
}

role=""; list=0; preset=""; list_presets=0; where=0; lead=0; exclude_lead=0; check=0; cfg=""; mcfg=""; excludes=()
while [ $# -gt 0 ]; do
  case "$1" in
    --config) [ $# -ge 2 ] || { echo "delegate-resolve: --config needs a file argument" >&2; usage; exit 2; }
              cfg="$2"; shift 2 ;;
    --models) [ $# -ge 2 ] || { echo "delegate-resolve: --models needs a file argument" >&2; usage; exit 2; }
              mcfg="$2"; shift 2 ;;
    --exclude) [ $# -ge 2 ] || { echo "delegate-resolve: --exclude needs a vendor or provider name" >&2; usage; exit 2; }
              excludes+=("$2"); shift 2 ;;
    --preset) [ $# -ge 2 ] || { echo "delegate-resolve: --preset needs a name" >&2; usage; exit 2; }
              preset="$2"; shift 2 ;;
    --list) list=1; shift ;;
    --list-presets) list_presets=1; shift ;;
    --where) where=1; shift ;;
    --lead) lead=1; shift ;;
    --exclude-lead) exclude_lead=1; shift ;;
    --check) check=1; shift ;;
    -h|--help) usage; exit 0 ;;
    -*) usage; exit 2 ;;
    *) role="$1"; shift ;;
  esac
done

# --- config layers -----------------------------------------------------------------
tomls=()
if [ -n "${DELEGATES_TOML:-}" ]; then
  tomls=("$DELEGATES_TOML")
elif [ -n "$cfg" ]; then
  tomls=("$cfg")
else
  [ -f ".megapowers/delegates.toml" ] && tomls+=(".megapowers/delegates.toml")
  user_toml="${XDG_CONFIG_HOME:-$HOME/.config}/megapowers/delegates.toml"
  [ -f "$user_toml" ] && tomls+=("$user_toml")
  tomls+=("$shipped")
fi
layers=()
for f in "${tomls[@]}"; do
  if [ ! -f "$f" ]; then echo "delegate-resolve: no config at $f" >&2; exit 2; fi
  if [ ! -r "$f" ]; then echo "delegate-resolve: cannot read $f (layer skipped)" >&2; continue; fi
  layers+=("$f")
done
[ "${#layers[@]}" -gt 0 ] || { echo "delegate-resolve: no readable config" >&2; exit 2; }

# --- catalog layers (models.toml) --------------------------------------------------
plugin_models="$here/../../../models.toml"   # <plugin root>/models.toml
mtomls=()
if [ -n "${MODELS_TOML:-}" ]; then
  mtomls=("$MODELS_TOML")
elif [ -n "$mcfg" ]; then
  mtomls=("$mcfg")
else
  [ -f ".megapowers/models.toml" ] && mtomls+=(".megapowers/models.toml")
  user_models="${XDG_CONFIG_HOME:-$HOME/.config}/megapowers/models.toml"
  [ -f "$user_models" ] && mtomls+=("$user_models")
  [ -f "$plugin_models" ] && mtomls+=("$plugin_models")
fi
mlayers=()
for f in ${mtomls[@]+"${mtomls[@]}"}; do
  if [ ! -f "$f" ]; then echo "delegate-resolve: no catalog at $f" >&2; exit 2; fi
  if [ ! -r "$f" ]; then echo "delegate-resolve: cannot read $f (layer skipped)" >&2; continue; fi
  mlayers+=("$f")
done

if [ "$where" -eq 1 ]; then
  printf '%s\n' "${layers[@]}"
  [ "${#mlayers[@]}" -gt 0 ] && printf '%s\n' "${mlayers[@]}"
  exit 0
fi

# --- restricted-TOML parse guard -----------------------------------------------------
# A syntactically broken layer must fail loudly (exit 2, naming file and line), not
# be mistaken for an unknown role (exit 3).
for f in "${layers[@]}" ${mlayers[@]+"${mlayers[@]}"}; do
  lint="$(awk '
    { s=$0; sub(/^[[:space:]]+/,"",s); sub(/[[:space:]]+$/,"",s) }
    s=="" || s ~ /^#/ { next }
    s ~ /^\[[A-Za-z0-9_.-]+\][[:space:]]*(#.*)?$/ { next }
    s ~ /^[A-Za-z0-9_.-]+[[:space:]]*=/ { next }
    { printf "%d\t%s", NR, $0; exit }
  ' "$f")"
  if [ -n "$lint" ]; then
    ln="${lint%%$'\t'*}"; txt="${lint#*$'\t'}"
    echo "delegate-resolve: parse error in $f at line $ln: $txt" >&2
    exit 2
  fi
done

# --- readers -------------------------------------------------------------------------
# Scalar and array lookups return the first (highest-priority) layer's value;
# existence checks and listings union across layers.

section_exists_in() { awk -v sec="[$2]" '{h=$0; gsub(/[[:space:]]/,"",h)} h==sec {found=1; exit} END{exit !found}' "$1"; }
section_exists() { local f; for f in "${layers[@]}"; do section_exists_in "$f" "$1" && return 0; done; return 1; }
key_exists_in() {  # $1=file $2=section $3=key
  awk -v sec="[$2]" -v key="$3" '
    { hn=$0; gsub(/[[:space:]]/,"",hn) }
    hn==sec {inx=1; next}
    /^[[:space:]]*\[/ {inx=0}
    inx && $0 ~ ("^[[:space:]]*" key "[[:space:]]*=") {found=1; exit}
    END {exit !found}
  ' "$1"
}

list_roles() {
  local f
  for f in "${layers[@]}"; do
    awk '{h=$0; gsub(/[[:space:]]/,"",h)} h=="[roles]"{r=1;next} /^[[:space:]]*\[/{r=0} r && /=/{l=$0;sub(/=.*/,"",l);gsub(/[[:space:]]/,"",l);if(l!="")print l}' "$f"
  done | awk '!seen[$0]++'
}

list_preset_names() {
  local f
  for f in "${layers[@]}"; do
    awk '{h=$0; gsub(/[[:space:]]/,"",h)} h ~ /^\[presets\./{n=h; sub(/^\[presets\./,"",n); sub(/\].*/,"",n); if(n!="")print n}' "$f"
  done | awk '!seen[$0]++'
}

section_val_in() {  # $1=file $2=section (e.g. "roles" | "providers.codex") $3=key
  awk -v sec="[$2]" -v key="$3" '
    { hn=$0; gsub(/[[:space:]]/,"",hn) }
    hn==sec {inx=1; next}
    /^[[:space:]]*\[/ {inx=0}
    inx && $0 ~ ("^[[:space:]]*" key "[[:space:]]*=") {
      rest=$0; sub(/^[^=]*=[[:space:]]*/,"",rest)
      if (rest ~ /^"/)      { sub(/^"/,"",rest); sub(/".*/,"",rest); print rest; exit }
      else if (rest ~ /^'\''/) { sub(/^'\''/,"",rest); sub(/'\''.*/,"",rest); print rest; exit }
      else { sub(/#.*/,"",rest); gsub(/[[:space:]]+$/,"",rest); print rest; exit }
    }
  ' "$1"
}
section_val() {  # $1=section $2=key -> first layer that defines the key wins
  local f v
  for f in "${layers[@]}"; do
    key_exists_in "$f" "$1" "$2" || continue
    v="$(section_val_in "$f" "$1" "$2")"
    printf '%s\n' "$v"
    return 0
  done
  return 1
}

array_val_in() {  # $1=file $2=section $3=key -> one element per line
  awk -v sec="[$2]" -v key="$3" '
    { hn=$0; gsub(/[[:space:]]/,"",hn) }
    hn==sec {inx=1; next}
    /^[[:space:]]*\[/ {inx=0}
    inx && $0 ~ ("^[[:space:]]*" key "[[:space:]]*=") {
      rest=$0; sub(/^[^=]*=/,"",rest)
      while (match(rest, /"[^"]*"/)) {
        print substr(rest, RSTART+1, RLENGTH-2)
        rest=substr(rest, RSTART+RLENGTH)
      }
      exit
    }
  ' "$1"
}
array_val() {  # $1=section $2=key -> the first layer that defines the key wins whole
  local f out
  for f in "${layers[@]}"; do
    key_exists_in "$f" "$1" "$2" || continue
    out="$(array_val_in "$f" "$1" "$2")"
    [ -n "$out" ] && printf '%s\n' "$out"
    return 0
  done
  return 1
}

msection_exists() { local f; for f in ${mlayers[@]+"${mlayers[@]}"}; do section_exists_in "$f" "$1" && return 0; done; return 1; }
msection_val() {
  local f v
  for f in ${mlayers[@]+"${mlayers[@]}"}; do
    key_exists_in "$f" "$1" "$2" || continue
    v="$(section_val_in "$f" "$1" "$2")"
    printf '%s\n' "$v"
    return 0
  done
  return 1
}
marray_val() {
  local f out
  for f in ${mlayers[@]+"${mlayers[@]}"}; do
    key_exists_in "$f" "$1" "$2" || continue
    out="$(array_val_in "$f" "$1" "$2")"
    [ -n "$out" ] && printf '%s\n' "$out"
    return 0
  done
  return 1
}

# Catalog data (lead, tiers, providers, floor) resolves DELEGATES stack first
# (legacy: inline provider sections and pre-0.3 override files win), then the
# catalog stack.
cat_exists() { section_exists "$1" || msection_exists "$1"; }
cat_val() {
  section_val "$1" "$2" && return 0
  msection_val "$1" "$2"
}
cat_array() {
  array_val "$1" "$2" && return 0
  marray_val "$1" "$2"
}

fallbacks_of() { array_val fallbacks "$1"; }

providers_list() {  # every [providers.X] name across layers (tier subsections excluded)
  local f
  for f in "${layers[@]}" ${mlayers[@]+"${mlayers[@]}"}; do
    awk '{h=$0; gsub(/[[:space:]]/,"",h)} h ~ /^\[providers\.[A-Za-z0-9_-]+\]$/ {n=h; sub(/^\[providers\./,"",n); sub(/\]$/,"",n); print n}' "$f"
  done | awk '!seen[$0]++'
}

# model id and tier for a provider: default_tier maps through [providers.X.tiers];
# a provider without default_tier falls back to its legacy `model` key (schema v1).
provider_model() {  # $1=provider ; prints "model<TAB>tier"
  local p="$1" dt m
  dt="$(cat_val "providers.$p" default_tier)"
  if [ -n "$dt" ]; then
    m="$(cat_val "providers.$p.tiers" "$dt")"
    if [ -z "$m" ]; then
      echo "delegate-resolve: provider '$p': default_tier '$dt' has no [providers.$p.tiers] entry" >&2
      return 2
    fi
    printf '%s\t%s\n' "$m" "$dt"
  else
    printf '%s\t\n' "$(cat_val "providers.$p" model)"
  fi
}

scale_list="$(cat_array tiers scale)"   # empty on v1 configs
tier_index() { printf '%s\n' "$scale_list" | grep -nx -- "$1" | cut -d: -f1; }

# --- --check mode ------------------------------------------------------------------
if [ "$check" -eq 1 ]; then
  errs=0
  note() { echo "delegate-resolve --check: $1" >&2; errs=$((errs+1)); }
  while IFS= read -r r; do
    [ -n "$r" ] || continue
    p="$(section_val roles "$r")"
    [ -n "$p" ] || continue
    cat_exists "providers.$p" || note "role '$r' routes to missing provider '$p'"
    while IFS= read -r fp; do
      [ -n "$fp" ] || continue
      cat_exists "providers.$fp" || note "fallback for '$r' names missing provider '$fp'"
    done <<< "$(fallbacks_of "$r")"
  done <<< "$(list_roles)"
  lp="$(cat_val lead provider)"
  if [ -n "$lp" ] && ! cat_exists "providers.$lp"; then note "[lead] provider '$lp' missing"; fi
  if [ -n "$lp" ] && cat_exists "providers.$lp"; then
    ltc="$(cat_val lead tier)"
    if [ -n "$ltc" ] && [ -z "$(cat_val "providers.$lp.tiers" "$ltc")" ]; then
      note "[lead] tier '$ltc' has no [providers.$lp.tiers] entry"
    fi
  fi
  fl="$(cat_val defaults floor)"
  if [ -n "$fl" ] && [ -n "$scale_list" ]; then
    ft="${fl%%:*}"
    printf '%s\n' "$scale_list" | grep -qx -- "$ft" || note "floor tier '$ft' not in [tiers] scale"
  fi
  ce_scale="$(cat_array efforts scale)"
  if [ -n "$fl" ] && [ -n "$ce_scale" ]; then
    fe="${fl#*:}"
    if [ "$fe" != "$fl" ] && [ -n "$fe" ]; then
      printf '%s\n' "$ce_scale" | grep -qx -- "$fe" || note "floor effort '$fe' not in [efforts] scale"
    fi
  fi
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    dt="$(cat_val "providers.$p" default_tier)"
    if [ -n "$dt" ]; then
      [ -n "$(cat_val "providers.$p.tiers" "$dt")" ] || note "provider '$p' default_tier '$dt' has no tier-map entry"
      if [ -n "$scale_list" ]; then
        printf '%s\n' "$scale_list" | grep -qx -- "$dt" || note "provider '$p' default_tier '$dt' not in [tiers] scale"
      fi
    fi
    ref="$(cat_val "providers.$p" reference)"
    if [ -n "$ref" ] && [ ! -f "$here/../$ref" ]; then note "provider '$p' reference file missing: $ref"; fi
    pe="$(cat_val "providers.$p" effort)"
    plist="$(cat_array "providers.$p" efforts)"
    if [ -n "$pe" ] && [ -n "$ce_scale" ]; then
      printf '%s\n' "$ce_scale" | grep -qx -- "$pe" || note "provider '$p' default effort '$pe' not in [efforts] scale"
    fi
    if [ -n "$pe" ] && [ -n "$plist" ]; then
      printf '%s\n' "$plist" | grep -qx -- "$pe" || note "provider '$p' default effort '$pe' not in its efforts list"
    fi
    if [ -n "$plist" ] && [ -n "$ce_scale" ]; then
      while IFS= read -r pev; do
        [ -n "$pev" ] || continue
        printf '%s\n' "$ce_scale" | grep -qx -- "$pev" || note "provider '$p' efforts entry '$pev' not in [efforts] scale"
      done <<< "$plist"
    fi
  done <<< "$(providers_list)"
  if [ "$errs" -eq 0 ]; then echo "delegate-resolve --check: OK (${layers[*]}${mlayers[*]:+ + ${mlayers[*]}})"; exit 0; fi
  exit 1
fi

# --- list / preset modes ---------------------------------------------------------
if [ "$list" -eq 1 ]; then list_roles; exit 0; fi
if [ "$list_presets" -eq 1 ]; then list_preset_names; exit 0; fi

if [ "$lead" -eq 1 ]; then
  lp="$(cat_val lead provider)"
  [ -n "$lp" ] || { echo "delegate-resolve: no [lead] section in ${layers[*]}" >&2; exit 3; }
  cat_exists "providers.$lp" || { echo "delegate-resolve: [lead] provider '$lp' has no [providers.$lp] section" >&2; exit 2; }
  lt="$(cat_val lead tier)"
  if [ -n "$lt" ]; then
    lm="$(cat_val "providers.$lp.tiers" "$lt")"
    if [ -z "$lm" ]; then
      echo "delegate-resolve: [lead] tier '$lt' has no [providers.$lp.tiers] entry" >&2
      exit 2
    fi
  else
    pm="$(provider_model "$lp")" || exit 2
    lm="${pm%%$'\t'*}"; lt="${pm#*$'\t'}"
  fi
  echo "LEAD_PROVIDER=$lp"
  [ -n "$lt" ] && echo "LEAD_TIER=$lt"
  echo "LEAD_MODEL=${lm:-}"
  lv="$(cat_val "providers.$lp" vendor)"
  [ -n "$lv" ] && echo "LEAD_VENDOR=$lv"
  exit 0
fi

if [ -n "$preset" ]; then
  if ! section_exists "presets.$preset"; then
    echo "delegate-resolve: no preset '$preset' in ${layers[*]}" >&2
    echo "presets available:" >&2; list_preset_names | sed 's/^/  /' >&2
    exit 3
  fi
  echo "PRESET=$preset"
  for k in sandbox approval worktree cap use; do
    v="$(section_val "presets.$preset" "$k")"
    [ -n "$v" ] && echo "$(printf '%s' "$k" | tr '[:lower:]' '[:upper:]')=$v"
  done
  exit 0
fi

[ -n "$role" ] || { usage; exit 2; }

if [ "$exclude_lead" -eq 1 ]; then
  lp="$(cat_val lead provider)"
  if [ -n "$lp" ]; then
    excludes+=("$lp")
    lv="$(cat_val "providers.$lp" vendor)"
    [ -n "$lv" ] && excludes+=("$lv")
  fi
fi

# --- role resolution -------------------------------------------------------------
primary="$(section_val roles "$role")"
if [ -z "$primary" ]; then
  echo "delegate-resolve: no route for role '$role' in ${layers[*]}" >&2
  echo "roles available:" >&2
  list_roles | sed 's/^/  /' >&2
  exit 3
fi

# candidate chain: the role's [fallbacks] (in order) or just its single provider.
candidates="$(fallbacks_of "$role")"
[ -n "$candidates" ] || candidates="$primary"

# a candidate is excluded when its provider name OR its vendor is in --exclude.
excluded() {  # $1=provider
  local p="$1" v x; v="$(cat_val "providers.$p" vendor)"
  [ "${#excludes[@]}" -gt 0 ] || return 1
  for x in "${excludes[@]}"; do
    [ "$x" = "$p" ] && return 0
    [ -n "$v" ] && [ "$x" = "$v" ] && return 0
  done
  return 1
}

floor="$(cat_val defaults floor)"
floor_idx=""
if [ -n "$floor" ] && [ -n "$scale_list" ]; then
  ftier="${floor%%:*}"
  floor_idx="$(tier_index "$ftier")"
  if [ -z "$floor_idx" ]; then
    echo "delegate-resolve: floor tier '$ftier' is not in the [tiers] scale" >&2
    exit 2
  fi
fi
# The floor's effort half validates against the [efforts] scale and becomes a
# minimum for providers that declare a default effort.
floor_effort_idx=""
effort_scale="$(cat_array efforts scale)"
if [ -n "$floor" ]; then
  feff="${floor#*:}"
  if [ "$feff" != "$floor" ] && [ -n "$feff" ]; then
    if [ -n "$effort_scale" ] && ! printf '%s\n' "$effort_scale" | grep -qx -- "$feff"; then
      echo "delegate-resolve: floor effort '$feff' is not in the [efforts] scale" >&2
      exit 2
    fi
    [ -n "$effort_scale" ] && floor_effort_idx="$(printf '%s\n' "$effort_scale" | grep -nx -- "$feff" | cut -d: -f1)"
  fi
fi
req="$(array_val requires "$role")"

selected=""; only_disabled=1
while IFS= read -r p; do
  [ -n "$p" ] || continue
  cat_exists "providers.$p" || {
    echo "delegate-resolve: role '$role' routes to provider '$p', but no [providers.$p] section exists in ${layers[*]}" >&2
    exit 2
  }
  if excluded "$p"; then only_disabled=0; continue; fi
  en="$(cat_val "providers.$p" enabled)"; en="${en:-true}"
  [ "$en" = "false" ] && continue                    # disabled -> try the next candidate
  only_disabled=0
  bin="$(cat_val "providers.$p" binary)"
  if [ -n "$bin" ] && ! command -v "$bin" >/dev/null 2>&1; then continue; fi   # absent -> next
  if [ -n "$req" ]; then
    caps="$(cat_array "providers.$p" capabilities)"
    capmiss=0
    while IFS= read -r rc_; do
      [ -n "$rc_" ] || continue
      printf '%s\n' "$caps" | grep -qx -- "$rc_" || { capmiss=1; break; }
    done <<< "$req"
    if [ "$capmiss" -eq 1 ]; then
      echo "delegate-resolve: provider '$p' lacks a required capability for role '$role' (skipped)" >&2
      continue
    fi
  fi
  if [ -n "$floor_idx" ]; then
    pdt="$(cat_val "providers.$p" default_tier)"
    if [ -n "$pdt" ]; then
      pidx="$(tier_index "$pdt")"
      if [ -n "$pidx" ] && [ "$pidx" -lt "$floor_idx" ]; then
        echo "delegate-resolve: provider '$p' tier '$pdt' is below floor '${floor%%:*}' (skipped)" >&2
        continue
      fi
    fi
  fi
  if [ -n "$floor_effort_idx" ]; then
    peff="$(cat_val "providers.$p" effort)"
    if [ -n "$peff" ]; then
      peff_idx="$(printf '%s\n' "$effort_scale" | grep -nx -- "$peff" | cut -d: -f1)"
      if [ -z "$peff_idx" ]; then
        echo "delegate-resolve: provider '$p' effort '$peff' is not in the [efforts] scale" >&2
        exit 2
      fi
      if [ "$peff_idx" -lt "$floor_effort_idx" ]; then
        echo "delegate-resolve: provider '$p' effort '$peff' is below floor '${floor#*:}' (skipped)" >&2
        continue
      fi
    fi
  fi
  selected="$p"; break
done <<< "$candidates"

if [ -z "$selected" ]; then
  # nothing usable: distinguish "the one provider is switched off" (exit 4) from
  # "everything was excluded, disabled along a chain, or its CLI is absent"
  # (exit 3). Exit 4 is a single-route contract, so a multi-candidate chain
  # never takes it, even when every candidate is disabled.
  n_cand="$(printf '%s\n' "$candidates" | grep -c .)"
  if [ "$only_disabled" -eq 1 ] && [ "$n_cand" -eq 1 ]; then
    sole="$(printf '%s\n' "$candidates" | grep -m1 .)"
    echo "ROLE=$role"
    echo "PROVIDER=$sole"
    pm="$(provider_model "$sole")" || exit 2
    dmodel="${pm%%$'\t'*}"; dtier="${pm#*$'\t'}"
    echo "MODEL=${dmodel:-}"
    [ -n "$dtier" ] && echo "TIER=$dtier"
    ef="$(cat_val "providers.$sole" effort)"
    [ -n "$ef" ] && echo "EFFORT=$ef"
    echo "CHANNEL=$(cat_val "providers.$sole" channel)"
    echo "ENABLED=false"
    [ -n "$floor" ] && echo "FLOOR=$floor"
    echo "delegate-resolve: provider '$sole' for role '$role' is DISABLED in config: enable it or re-route the role before dispatching." >&2
    exit 4
  fi
  echo "delegate-resolve: no available route for role '$role': every candidate is excluded, disabled, or its CLI is not installed." >&2
  echo "candidates tried: $(printf '%s' "$candidates" | tr '\n' ' ')" >&2
  exit 3
fi

# --- emit the resolved route -----------------------------------------------------
pm="$(provider_model "$selected")" || exit 2
model="${pm%%$'\t'*}"; tier="${pm#*$'\t'}"
effort="$(cat_val "providers.$selected" effort)"
channel="$(cat_val "providers.$selected" channel)"
vendor="$(cat_val "providers.$selected" vendor)"
binv="$(cat_val "providers.$selected" binary)"
notes="$(cat_val "providers.$selected" notes)"

echo "ROLE=$role"
echo "PROVIDER=$selected"
echo "MODEL=${model:-}"
[ -n "$tier" ] && echo "TIER=$tier"
[ -n "$effort" ] && echo "EFFORT=$effort"
echo "CHANNEL=${channel:-}"
echo "ENABLED=true"
[ -n "$vendor" ] && echo "VENDOR=$vendor"
[ -n "$binv" ] && echo "BINARY=$binv"
[ -n "$floor" ] && echo "FLOOR=$floor"
[ -n "$notes" ] && echo "NOTES=$notes"
exit 0   # explicit: the last `[ -n ... ] && echo` returns 1 when a field is empty
