{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Megapowers Review Verdict v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "findings", "next_steps", "evidence"],
  "properties": {
    "verdict": {"enum": ["approve", "needs_attention"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "lines", "confidence", "finding", "recommendation"],
        "properties": {
          "severity": {"enum": ["critical", "major", "minor"]},
          "file": {"type": "string"},
          "lines": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "finding": {"type": "string"},
          "recommendation": {"type": "string"}
        }
      }
    },
    "next_steps": {"type": "array", "items": {"type": "string"}},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "screenshots"],
      "properties": {
        "commands": {"type": "array", "items": {"type": "string"}},
        "screenshots": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
