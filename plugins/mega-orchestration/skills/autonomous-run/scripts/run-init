#!/usr/bin/env bash
# run-init <run-id> [--base DIR] [--level LEVEL] — scaffold a durable run directory
# (.megapowers/run/<id>/) with the file contract. Refuses to overwrite an existing
# charter.md: the charter is frozen, and a changed goal is a new run (so there is no
# --force — to genuinely start over, use a new run-id). Portable: bash + coreutils.
set -uo pipefail

id=""; base="${MEGAPOWERS_RUN_DIR:-.megapowers/run}"; level="on-the-loop"; model="${MEGAPOWERS_MODEL:-}"; replan=0
usage() { echo "usage: run-init <run-id> [--base DIR] [--level autonomous|on-the-loop|in-the-loop] [--model MODEL-ID] [--replan]" >&2; }
scriptdir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=run-lib.sh
. "$scriptdir/run-lib.sh"

# plan_digest <plan.md> — emit "<tag> <sha256>" per milestone: the hash covers the
# milestone heading plus its acceptance line(s), whitespace-normalized. This is the
# frozen fingerprint --replan re-snapshots and run-derive/run-verify compare against.
plan_digest() {
  awk '
    function norm(s) { gsub(/[ \t]+/, " ", s); sub(/^ +/, "", s); sub(/ +$/, "", s); return s }
    /^## [A-Za-z][A-Za-z0-9_-]*:/ {
      if (tag != "") print tag "\t" buf
      tag = substr($0, 4, index($0, ":") - 4); buf = norm($0); next
    }
    /^## / { if (tag != "") print tag "\t" buf; tag = ""; buf = ""; next }
    tag != "" && $0 ~ /^[ \t]*-?[ \t]*acceptance:/ { buf = buf " ][ " norm($0) }
    END { if (tag != "") print tag "\t" buf }
  ' "$1" | while IFS="$(printf '\t')" read -r t c; do
    printf '%s %s\n' "$t" "$(printf '%s' "$c" | sha256sum | cut -d' ' -f1)"
  done
}
write_plan_digest() { [ -f "$1/plan.md" ] || return 0; plan_digest "$1/plan.md" > "$1/plan-digest"; }

while [ $# -gt 0 ]; do
  case "$1" in
    --base) [ $# -ge 2 ] || { usage; exit 2; }; base="$2"; shift 2 ;;
    --level) [ $# -ge 2 ] || { usage; exit 2; }; level="$2"; shift 2 ;;
    --model) [ $# -ge 2 ] || { usage; exit 2; }; model="$2"; shift 2 ;;
    --replan) replan=1; shift ;;
    -h|--help) usage; exit 0 ;;
    -*) usage; exit 2 ;;
    *) id="$1"; shift ;;
  esac
done
[ -n "$id" ] || { usage; exit 2; }
validate_run_id "$id" run-init || exit 2
case "$level" in autonomous|on-the-loop|in-the-loop) ;; *) echo "run-init: unknown level '$level'" >&2; exit 2 ;; esac

dir="$base/$id"

# --replan inverts the freeze guard: it re-snapshots plan-digest for an EXISTING run
# (so a deliberate plan change is auditable) and fails when the run is absent. It
# never rewrites the frozen charter — only plan-digest, plus one decision entry.
if [ "$replan" -eq 1 ]; then
  if [ ! -f "$dir/charter.md" ]; then
    echo "run-init: --replan needs an existing run at $dir (no charter.md found). Init it first, or drop --replan." >&2
    exit 3
  fi
  if [ -n "$model" ]; then
    MEGAPOWERS_RUN_DIR="$base" MEGAPOWERS_MODEL="$model" "$scriptdir/run-journal" "$id" decision 1.0 "re-plan applied: plan.md milestones re-snapshotted into plan-digest; charter unchanged"
  else
    MEGAPOWERS_RUN_DIR="$base" "$scriptdir/run-journal" "$id" decision 1.0 "re-plan applied: plan.md milestones re-snapshotted into plan-digest; charter unchanged"
  fi
  write_plan_digest "$dir"
  echo "run-init: re-planned $dir (plan-digest re-snapshotted from plan.md; charter stays frozen)"
  exit 0
fi

if [ -f "$dir/charter.md" ]; then
  echo "run-init: $dir/charter.md exists — the charter is frozen. Use a new run-id to start over." >&2
  exit 3
fi
mkdir -p "$dir"
# self-ignoring: run state is runtime data, never committed (works in any project)
[ -f "$base/.gitignore" ] || printf '*\n' > "$base/.gitignore"
ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)"

cat > "$dir/charter.md" <<EOF
# Charter: $id
Created: $ts  (FROZEN — do not edit; a changed goal is a new run)

## Goal
<what this run must achieve — one paragraph>

## Done when (acceptance criteria)
- [ ] <criterion 1 — prefer an executable check>
- [ ] <criterion 2>

## Autonomy level
$level

## Caps
- budget: <token/cost cap or "none">
- turns: <max turns or "none">
- blast radius: <what this run may NOT touch — e.g. no prod, no external sends>
EOF

if [ -f "$dir/plan.md" ]; then
  plan_authored=1   # the caller supplied a real plan; freeze it below
else
  plan_authored=0   # we are about to scaffold a placeholder template
  cat > "$dir/plan.md" <<'EOF'
# Plan
Milestones (each with its own acceptance check; prefer an executable oracle):

## M1: <name>
- acceptance: <test/compile/eval that decides done>
- status: pending
EOF
fi

# Fingerprint the plan into plan-digest so a later gut-the-plan or weaken-acceptance
# edit is detectable (run-derive-status/run-verify-status compare against it). Only a
# plan the caller authored (present at init) is frozen — a freshly scaffolded
# placeholder is a template, not a declaration, so freezing it would flag the normal
# fill-in-the-plan edit as tampering. Freeze a scaffolded plan after editing it with
# run-init <id> --replan. run-journal never updates the digest.
if [ "$plan_authored" -eq 1 ] && [ ! -f "$dir/plan-digest" ]; then write_plan_digest "$dir"; fi

[ -f "$dir/runbook.md" ] || cat > "$dir/runbook.md" <<'EOF'
# Runbook
Loop: read status -> next unmet milestone -> do it -> run its acceptance check ->
journal the result -> advance status. Trust the files over memory after a restart.
On failure: fix and re-verify, capped at 3 attempts, then mark blocked and move on.
Provenance: init the run with --model <your model id>, or prefix every journal
call inline (MEGAPOWERS_MODEL=<id> run-journal ...). A plain export does NOT
survive between tool calls; each runs in a fresh shell.
Before claiming finished: scripts/run-verify-status <run-id> must pass — it stamps
LAST_VERIFY into status. STATE=done with LAST_VERIFY=none means never certified.
EOF

[ -f "$dir/journal.md" ] || printf '# Journal (append-only)\n' > "$dir/journal.md"
[ -f "$dir/status" ]     || printf 'STATE=initialized\nCURSOR=M1\nLEVEL=%s\nLAST_VERIFY=none\n' "$level" > "$dir/status"
# persisted provenance: run-journal reads this when MEGAPOWERS_MODEL is unset
# (tool-call shells are fresh per call, so an env var cannot carry provenance)
[ -n "$model" ] && [ ! -f "$dir/model" ] && printf '%s\n' "$model" > "$dir/model"

echo "run-init: scaffolded $dir (level=$level${model:+, model=$model})"
if [ -z "$model" ]; then
  echo "run-init: no --model given — pass --model <your model id> (or prefix journal calls with MEGAPOWERS_MODEL=<id>) so journal provenance is recorded"
fi
exit 0
