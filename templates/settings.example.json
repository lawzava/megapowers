{
  "includeCoAuthoredBy": false,
  "attribution": { "commit": "", "pr": "" },
  "permissions": {
    "allow": [
      "Bash(playwright-cli:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "credentials": {
      "files": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.netrc", "~/.pgpass", ".env"],
      "envVars": ["GITHUB_TOKEN", "NPM_TOKEN", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"]
    }
  }
}
